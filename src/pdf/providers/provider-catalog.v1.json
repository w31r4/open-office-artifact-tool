{
  "schema": "open-office-artifact-tool.pdf-provider-catalog.v1",
  "schemaVersion": 1,
  "releasePolicy": {
    "managedArtifacts": "versioned-signed-platform-release-assets",
    "forbidLatestUrls": true,
    "forbidGlobalInstallers": true,
    "cacheScope": "project-private",
    "defaultInstallPolicy": "disabled",
    "managedPlatforms": ["darwin-arm64", "linux-x64"]
  },
  "packs": {
    "core-js": {
      "state": "built-in",
      "delivery": "npm-package",
      "platforms": ["any"],
      "version": "package-version",
      "artifacts": [],
      "requiresPackIds": [],
      "entrypoints": [],
      "dependencyClosure": ["open-office-artifact-tool"],
      "estimatedDownloadBytes": 0,
      "estimatedUnpackedBytes": 0,
      "license": { "expression": "AGPL-3.0-or-later", "requiresAcknowledgement": false }
    },
    "mupdf-js": {
      "state": "built-in",
      "delivery": "npm-package",
      "platforms": ["any"],
      "version": "1.28.0",
      "artifacts": [],
      "requiresPackIds": [],
      "entrypoints": [],
      "dependencyClosure": ["mupdf@1.28.0"],
      "estimatedDownloadBytes": 0,
      "estimatedUnpackedBytes": 0,
      "license": { "expression": "AGPL-3.0-or-later", "requiresAcknowledgement": false }
    },
    "python-foundation": {
      "state": "unpublished",
      "delivery": "versioned-signed-platform-release-asset",
      "platforms": ["darwin-arm64", "linux-x64"],
      "version": null,
      "artifacts": [],
      "requiresPackIds": [],
      "entrypoints": [{ "path": "bin/python3", "kind": "file", "executable": true }],
      "dependencyClosure": ["isolated CPython", "reportlab", "pdfplumber", "pypdf"],
      "estimatedDownloadBytes": null,
      "estimatedUnpackedBytes": null,
      "license": { "expression": "BSD-3-Clause AND MIT", "requiresAcknowledgement": false }
    },
    "python-specialists": {
      "state": "unpublished",
      "delivery": "versioned-signed-platform-release-asset",
      "platforms": ["darwin-arm64", "linux-x64"],
      "version": null,
      "artifacts": [],
      "requiresPackIds": ["qpdf"],
      "entrypoints": [{ "path": "bin/python3", "kind": "file", "executable": true }],
      "dependencyClosure": ["isolated CPython", "PyMuPDF", "pikepdf", "pyHanko", "pyhanko-certvalidator", "qpdf runtime"],
      "estimatedDownloadBytes": null,
      "estimatedUnpackedBytes": null,
      "license": { "expression": "AGPL-3.0-or-later AND MIT AND MPL-2.0", "requiresAcknowledgement": true, "id": "python-specialists-license", "acceptedValues": ["agpl", "commercial"] }
    },
    "poppler-qa": {
      "state": "unpublished",
      "delivery": "versioned-signed-platform-release-asset",
      "platforms": ["darwin-arm64", "linux-x64"],
      "version": null,
      "artifacts": [],
      "requiresPackIds": [],
      "entrypoints": [
        { "path": "bin/pdfinfo", "kind": "file", "executable": true },
        { "path": "bin/pdftoppm", "kind": "file", "executable": true }
      ],
      "dependencyClosure": ["Poppler CLI"],
      "estimatedDownloadBytes": null,
      "estimatedUnpackedBytes": null,
      "license": { "expression": "GPL-2.0-or-later", "requiresAcknowledgement": false }
    },
    "qpdf": {
      "state": "unpublished",
      "delivery": "versioned-signed-platform-release-asset",
      "platforms": ["darwin-arm64", "linux-x64"],
      "version": null,
      "artifacts": [],
      "requiresPackIds": [],
      "entrypoints": [{ "path": "bin/qpdf", "kind": "file", "executable": true }],
      "dependencyClosure": ["qpdf CLI >=11"],
      "estimatedDownloadBytes": null,
      "estimatedUnpackedBytes": null,
      "license": { "expression": "Apache-2.0", "requiresAcknowledgement": false }
    },
    "ocr-core": {
      "state": "unpublished",
      "delivery": "versioned-signed-platform-release-asset",
      "platforms": ["darwin-arm64", "linux-x64"],
      "version": null,
      "artifacts": [],
      "requiresPackIds": ["qpdf", "poppler-qa"],
      "entrypoints": [
        { "path": "bin/ocrmypdf", "kind": "file", "executable": true },
        { "path": "bin/tesseract", "kind": "file", "executable": true },
        { "path": "share/tessdata", "kind": "directory", "executable": false }
      ],
      "dependencyClosure": ["isolated Python", "OCRmyPDF", "Tesseract", "qpdf", "Poppler"],
      "estimatedDownloadBytes": null,
      "estimatedUnpackedBytes": null,
      "license": { "expression": "MPL-2.0 AND Apache-2.0 AND GPL-2.0-or-later", "requiresAcknowledgement": false }
    },
    "ocr-language-eng": {
      "state": "unpublished",
      "delivery": "versioned-signed-platform-release-asset",
      "platforms": ["darwin-arm64", "linux-x64"],
      "version": null,
      "artifacts": [],
      "requiresPackIds": [],
      "entrypoints": [{ "path": "share/tessdata/eng.traineddata", "kind": "file", "executable": false }],
      "dependencyClosure": ["Tesseract English traineddata"],
      "estimatedDownloadBytes": null,
      "estimatedUnpackedBytes": null,
      "license": { "expression": "Apache-2.0", "requiresAcknowledgement": false }
    },
    "ocr-language-chi-sim": {
      "state": "unpublished",
      "delivery": "versioned-signed-platform-release-asset",
      "platforms": ["darwin-arm64", "linux-x64"],
      "version": null,
      "artifacts": [],
      "requiresPackIds": [],
      "entrypoints": [{ "path": "share/tessdata/chi_sim.traineddata", "kind": "file", "executable": false }],
      "dependencyClosure": ["Tesseract Simplified Chinese traineddata"],
      "estimatedDownloadBytes": null,
      "estimatedUnpackedBytes": null,
      "license": { "expression": "Apache-2.0", "requiresAcknowledgement": false }
    },
    "verapdf": {
      "state": "unpublished",
      "delivery": "versioned-signed-platform-release-asset",
      "platforms": ["darwin-arm64", "linux-x64"],
      "version": null,
      "artifacts": [],
      "requiresPackIds": [],
      "entrypoints": [
        { "path": "bin/verapdf", "kind": "file", "executable": true },
        { "path": "jre/bin/java", "kind": "file", "executable": true }
      ],
      "dependencyClosure": ["veraPDF CLI >=1.30,<1.31", "managed JRE"],
      "estimatedDownloadBytes": null,
      "estimatedUnpackedBytes": null,
      "license": { "expression": "MPL-2.0", "requiresAcknowledgement": false }
    }
  },
  "providers": {
    "artifact-tool": {
      "kind": "core",
      "packId": "core-js",
      "role": "greenfield tagged semantic model",
      "integration": "shipped-js-api",
      "taskIds": ["create-tagged", "inspect"],
      "license": { "expression": "AGPL-3.0-or-later", "requiresAcknowledgement": false },
      "matrixBoundary": "Use only for a new PdfArtifact or a trusted source model. It is not an imported-PDF fidelity editor."
    },
    "mupdf-js": {
      "kind": "node-package",
      "packId": "mupdf-js",
      "package": "mupdf",
      "exactVersion": "1.28.0",
      "role": "default arbitrary-PDF inspect, render, and bounded direct-original edit",
      "integration": "shipped-js-api-runtime-lazy",
      "taskIds": ["extract", "inspect", "edit-content", "fill-form", "annotate", "redact", "render"],
      "license": { "expression": "AGPL-3.0-or-later", "requiresAcknowledgement": false },
      "matrixBoundary": "This is the required lazy default. Its bounded direct-original operations are not Word-style reflow, full sanitize, or a signature authority."
    },
    "reportlab": {
      "kind": "python-module",
      "packId": "python-foundation",
      "module": "reportlab",
      "role": "greenfield visual/layout-oriented generation",
      "integration": "shipped-thin-script",
      "taskIds": ["create-layout"],
      "managedRuntime": { "pythonPath": "bin/python3", "environment": { "OPEN_OFFICE_PDF_PROVIDER_PYTHON": "bin/python3" } },
      "license": { "expression": "BSD-3-Clause", "requiresAcknowledgement": false },
      "matrixBoundary": "New documents only; it does not inherit PdfArtifact tagged/reading-order semantics."
    },
    "pdfplumber": {
      "kind": "python-module",
      "packId": "python-foundation",
      "module": "pdfplumber",
      "role": "read-only text, word-geometry, table, line, and rectangle extraction",
      "integration": "shipped-thin-script",
      "taskIds": ["extract"],
      "managedRuntime": { "pythonPath": "bin/python3", "environment": { "OPEN_OFFICE_PDF_PROVIDER_PYTHON": "bin/python3" } },
      "license": { "expression": "MIT", "requiresAcknowledgement": false },
      "matrixBoundary": "Extraction is evidence, not layout fidelity or an edit representation."
    },
    "pypdf": {
      "kind": "python-module",
      "packId": "python-foundation",
      "module": "pypdf",
      "role": "basic structure, attachment quarantine, complete-source merge/reorder/selective stamp, forms, annotations",
      "integration": "shipped-thin-script",
      "taskIds": ["extract", "extract-attachments", "inspect", "fill-form", "annotate", "merge-stamp"],
      "managedRuntime": { "pythonPath": "bin/python3", "environment": { "OPEN_OFFICE_PDF_PROVIDER_PYTHON": "bin/python3" } },
      "license": { "expression": "BSD-3-Clause", "requiresAcknowledgement": false },
      "matrixBoundary": "Inspect signatures and DocMDP before mutation; an incremental byte layout is not signature authorization."
    },
    "pymupdf": {
      "kind": "python-module",
      "packId": "python-specialists",
      "module": "pymupdf",
      "minimumVersion": "1.27.2",
      "maximumVersionExclusive": "1.28.0",
      "role": "advanced imported-PDF editing, image-backed OCR redaction, and sanitize",
      "integration": "shipped-thin-script-external-python",
      "taskIds": ["extract", "inspect", "edit-content", "fill-form", "annotate", "redact", "sanitize"],
      "managedRuntime": { "pythonPath": "bin/python3", "environment": { "OPEN_OFFICE_PDF_PROVIDER_PYTHON": "bin/python3" } },
      "license": { "id": "agpl-or-commercial", "expression": "AGPL-3.0-or-later OR commercial", "requiresAcknowledgement": true, "acceptedValues": ["agpl", "commercial"] },
      "matrixBoundary": "Explicit advanced provider only. Sanitization is full-rewrite and residue-scanned; PyMuPDF is not the digital-signature authority."
    },
    "poppler": {
      "kind": "command",
      "packId": "poppler-qa",
      "commands": ["pdfinfo", "pdftoppm"],
      "role": "independent native file/render QA",
      "integration": "shipped-js-adapter-and-cli-workflow",
      "taskIds": ["render"],
      "managedRuntime": {
        "commandPaths": { "pdfinfo": "bin/pdfinfo", "pdftoppm": "bin/pdftoppm" },
        "environment": { "OPEN_OFFICE_PDF_PDFINFO": "bin/pdfinfo", "OPEN_OFFICE_PDF_PDFTOPPM": "bin/pdftoppm" }
      },
      "license": { "expression": "GPL-2.0-or-later", "requiresAcknowledgement": false },
      "matrixBoundary": "Independent renderer/file evidence only; it is not an editor or conformance validator."
    },
    "qpdf": {
      "kind": "command",
      "packId": "qpdf",
      "commands": ["qpdf"],
      "environment": "OPEN_OFFICE_PDF_QPDF",
      "minimumMajor": 11,
      "requireVersionOutput": true,
      "role": "bounded structure inspection, recovery rewrite, and linearization",
      "integration": "shipped-thin-script-external-cli",
      "taskIds": ["inspect", "repair", "linearize"],
      "managedRuntime": { "commandPaths": { "qpdf": "bin/qpdf" }, "environment": { "OPEN_OFFICE_PDF_QPDF": "bin/qpdf" } },
      "license": { "expression": "Apache-2.0", "requiresAcknowledgement": false },
      "matrixBoundary": "Not a renderer, text extractor, strict conformance checker, sanitizer, password workflow, or signature validator."
    },
    "pikepdf": {
      "kind": "python-module",
      "packId": "python-specialists",
      "module": "pikepdf",
      "minimumVersion": "10.10.0",
      "maximumVersionExclusive": "10.11.0",
      "role": "source-bound active and auxiliary PDF structure cleanup",
      "integration": "shipped-thin-script-external-python",
      "taskIds": ["inspect", "structure-clean"],
      "managedRuntime": { "pythonPath": "bin/python3", "environment": { "OPEN_OFFICE_PDF_PROVIDER_PYTHON": "bin/python3" } },
      "license": { "expression": "MPL-2.0", "requiresAcknowledgement": false },
      "matrixBoundary": "A curated fixed-profile rewrite, not redaction, metadata/form/XFA cleanup, strict sanitize, rendering, or malware isolation."
    },
    "pyhanko": {
      "kind": "python-module",
      "packId": "python-specialists",
      "module": "pyhanko",
      "distribution": "pyHanko",
      "minimumVersion": "0.35.0",
      "maximumVersionExclusive": "0.36.0",
      "companionModule": "pyhanko_certvalidator",
      "companionDistribution": "pyhanko-certvalidator",
      "companionMinimumVersion": "0.31.0",
      "companionMaximumVersionExclusive": "0.32.0",
      "role": "source-bound local-PKCS#12 signing plus read-only signature validation",
      "integration": "shipped-thin-script-external-python",
      "taskIds": ["sign", "verify-signature"],
      "managedRuntime": { "pythonPath": "bin/python3", "environment": { "OPEN_OFFICE_PDF_PROVIDER_PYTHON": "bin/python3" } },
      "license": { "expression": "MIT", "requiresAcknowledgement": false },
      "matrixBoundary": "The runtime can be selected, but certificates, private keys, HSMs, and remote-signing credentials are always caller-provided and never acquired automatically."
    },
    "verapdf": {
      "kind": "command",
      "packId": "verapdf",
      "commands": ["verapdf"],
      "environment": "OPEN_OFFICE_PDF_VERAPDF",
      "minimumVersion": "1.30.0",
      "maximumVersionExclusive": "1.31.0",
      "requireVersionOutput": true,
      "role": "source-bound PDF/A and PDF/UA machine-rule validation",
      "integration": "shipped-thin-script-external-cli",
      "taskIds": ["validate-conformance"],
      "managedRuntime": { "commandPaths": { "verapdf": "bin/verapdf" }, "environment": { "OPEN_OFFICE_PDF_VERAPDF": "bin/verapdf" } },
      "license": { "expression": "MPL-2.0", "requiresAcknowledgement": false },
      "matrixBoundary": "One explicit built-in profile only; a green machine report is not universal accessibility certification or repair."
    },
    "ocrmypdf": {
      "kind": "command",
      "packId": "ocr-core",
      "commands": ["ocrmypdf"],
      "environment": "OPEN_OFFICE_PDF_OCRMYPDF",
      "minimumVersion": "17.8.0",
      "maximumVersionExclusive": "17.9.0",
      "requireVersionOutput": true,
      "role": "source-bound scanned-PDF OCR and searchable layer generation",
      "integration": "shipped-thin-script-external-cli",
      "taskIds": ["ocr"],
      "managedRuntime": { "commandPaths": { "ocrmypdf": "bin/ocrmypdf", "tesseract": "bin/tesseract" }, "environment": { "OPEN_OFFICE_PDF_OCRMYPDF": "bin/ocrmypdf" } },
      "license": { "expression": "MPL-2.0", "requiresAcknowledgement": false },
      "matrixBoundary": "OCR is a source-bound rewrite with isolated native sidecars and explicit language packs; it is not proof of text correctness or PDF/UA repair."
    },
    "tesseract": {
      "kind": "command",
      "packId": "ocr-core",
      "commands": ["tesseract"],
      "role": "OCR engine used by strict image residue checks",
      "integration": "external-required-for-image-ocr",
      "taskIds": [],
      "managedRuntime": { "commandPaths": { "tesseract": "bin/tesseract" }, "environment": { "TESSDATA_PREFIX": "share/tessdata" } },
      "license": { "expression": "Apache-2.0", "requiresAcknowledgement": false },
      "matrixBoundary": "Only use after the caller has selected an OCR workflow and explicit language packs; never auto-download a language."
    }
  },
  "ocrLanguagePacks": {
    "eng": "ocr-language-eng",
    "chi_sim": "ocr-language-chi-sim"
  },
  "tasks": {
    "create-tagged": { "providers": ["artifact-tool"], "defaultProvider": "artifact-tool", "strategies": ["rewrite"], "input": "none" },
    "create-layout": { "providers": ["reportlab"], "strategies": ["rewrite"], "input": "none" },
    "extract": { "providers": ["mupdf-js", "pdfplumber", "pypdf", "pymupdf"], "defaultProvider": "mupdf-js", "strategies": ["read-only"], "input": "existing" },
    "extract-attachments": { "providers": ["pypdf"], "strategies": ["read-only"], "input": "existing" },
    "inspect": { "providers": ["mupdf-js", "artifact-tool", "pypdf", "pymupdf", "qpdf", "pikepdf"], "defaultProvider": "mupdf-js", "strategies": ["read-only"], "input": "existing" },
    "edit-content": { "providers": ["mupdf-js", "pymupdf"], "defaultProvider": "mupdf-js", "strategies": ["rewrite", "incremental"], "input": "existing", "mutation": true },
    "fill-form": { "providers": ["mupdf-js", "pypdf", "pymupdf"], "defaultProvider": "mupdf-js", "strategies": ["rewrite", "incremental"], "input": "existing", "mutation": true },
    "annotate": { "providers": ["mupdf-js", "pypdf", "pymupdf"], "defaultProvider": "mupdf-js", "strategies": ["rewrite", "incremental"], "input": "existing", "mutation": true },
    "merge-stamp": { "providers": ["pypdf"], "strategies": ["rewrite"], "input": "existing", "mutation": true },
    "repair": { "providers": ["qpdf"], "strategies": ["rewrite"], "input": "existing", "mutation": true, "invalidateSignatures": true },
    "linearize": { "providers": ["qpdf"], "strategies": ["rewrite"], "input": "existing", "mutation": true },
    "structure-clean": { "providers": ["pikepdf"], "strategies": ["rewrite"], "input": "existing", "mutation": true, "invalidateSignatures": true },
    "ocr": { "providers": ["ocrmypdf"], "strategies": ["rewrite"], "input": "existing", "mutation": true, "ocrLanguages": true },
    "sign": { "providers": ["pyhanko"], "strategies": ["incremental"], "input": "existing", "mutation": true, "credentials": ["local-pkcs12"] },
    "verify-signature": { "providers": ["pyhanko"], "strategies": ["read-only"], "input": "existing" },
    "validate-conformance": { "providers": ["verapdf"], "strategies": ["read-only"], "input": "existing" },
    "redact": { "providers": ["mupdf-js", "pymupdf"], "defaultProvider": "mupdf-js", "strategies": ["sanitize"], "input": "existing", "mutation": true, "invalidateSignatures": true },
    "sanitize": { "providers": ["pymupdf"], "strategies": ["sanitize"], "input": "existing", "mutation": true, "invalidateSignatures": true },
    "render": { "providers": ["mupdf-js", "poppler"], "defaultProvider": "mupdf-js", "strategies": ["read-only"], "input": "existing" }
  }
}
