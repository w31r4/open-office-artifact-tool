{"record":"case","id":"pdf-greenfield-accessible-report","family":"pdf","skill":"pdf","status":"ready","tags":["create","tagged-pdf","accessibility","tables"],"prompt":"根据附件数据和图片说明创建一份 6 页董事会可访问性报告。必须有真实 H1–H3 层级、文档标题和语言、跨页语义表格、Figure 替代文本、有意义的链接、作为 artifact 的页眉页脚和明确阅读顺序。请区分 package 自身的 modeled verify、veraPDF 机器检查和仍需人工判断的 PDF/UA 项目，不能把其中任意一个冒充完整 PDF/UA 认证。","inputs":[{"kind":"inline","to":"inputs/report-data.json","content":"{\"title\":\"Agent Artifact Readiness\",\"language\":\"zh-CN\",\"sections\":[{\"heading\":\"执行摘要\",\"metrics\":[[\"格式\",\"通过率\"],[\"PDF\",0.91],[\"DOCX\",0.96],[\"XLSX\",0.94],[\"PPTX\",0.93]]},{\"heading\":\"风险与缓解\",\"rows\":[[\"签名策略\",\"高\",\"强制 fail closed\"],[\"脱敏残留\",\"高\",\"多通道扫描\"],[\"视觉漂移\",\"中\",\"逐页渲染\"]]}],\"figureAlt\":\"柱状图比较四种文件格式的评测通过率，DOCX 最高为 96%，PDF 最低为 91%。\"}"}],"deliverables":[{"path":"outputs/readiness-report.pdf","mime":"application/pdf"},{"path":"outputs/audit.json","mime":"application/json"}],"expectedOutcome":"success","requires":{"providers":["artifact-tool","poppler"],"optionalProviders":["verapdf"],"features":["tagged-pdf"]},"policy":{"sourceImmutable":true,"network":false,"save":"rewrite","trials":3},"grade":{"machine":{"pageCount":6,"tagged":true,"language":"zh-CN","headingLevels":[1,2,3],"tableStructure":true,"figureAlt":true,"readingOrder":true},"visual":{"allPages":true,"noClipping":true,"crossPageTableReadable":true},"security":{"gate":false,"noPdfUaOverclaim":true},"trace":{"skill":"pdf","provider":"artifact-tool","save":"rewrite","noSilentFallback":true}},"sources":["https://pdfa.org/resource/pdfua-reference-suite/","https://docs.verapdf.org/validation/"]}
