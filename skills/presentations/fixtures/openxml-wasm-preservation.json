      "slideIndex": 0,
      "shapeName": "wasm-title",
      "text": [
        {
          "runs": [
            {
              "text": "After OpenXML WASM",
              "style": { "fontSize": 36, "bold": true, "color": "#0F172A" }
            }
          ]
        }
      ]
