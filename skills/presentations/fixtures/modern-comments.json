{
  "name": "core-review",
  "outputName": "core-review.pptx",
  "slideSize": { "width": 1280, "height": 720 },
  "slides": [
    {
      "name": "Review supported objects",
      "shapes": [
        {
          "name": "review-title",
          "geometry": "textbox",
          "position": { "left": 60, "top": 36, "width": 1160, "height": 70 },
          "fill": "transparent",
          "line": { "fill": "transparent", "width": 0 },
          "text": "Review semantic and visual evidence",
          "textStyle": { "fontFamily": "Arial", "fontSize": 38, "bold": true, "color": "#0F172A" }
        },
        {
          "name": "semantic-card",
          "geometry": "roundRect",
          "position": { "left": 72, "top": 150, "width": 330, "height": 150 },
          "fill": "#E0F2FE",
          "line": { "fill": "#0284C7", "width": 2 },
          "shadow": { "color": "#000000", "blurRadius": 7, "distance": 3, "direction": 45, "opacity": 0.18 },
          "text": [
            { "runs": [{ "text": "Semantic", "style": { "fontSize": 27, "bold": true, "color": "#0C4A6E" } }] },
            { "bulletCharacter": "•", "marginLeft": 24, "indent": -12, "runs": [{ "text": "Inspect structure", "style": { "fontSize": 18, "color": "#334155" } }] }
          ]
        },
        {
          "name": "visual-card",
          "geometry": "roundRect",
          "position": { "left": 474, "top": 150, "width": 330, "height": 150 },
          "fill": "#DCFCE7",
          "line": { "fill": "#16A34A", "width": 2 },
          "shadow": { "color": "#000000", "blurRadius": 7, "distance": 3, "direction": 45, "opacity": 0.18 },
          "text": [
            { "runs": [{ "text": "Visual", "style": { "fontSize": 27, "bold": true, "color": "#14532D" } }] },
            { "bulletCharacter": "•", "marginLeft": 24, "indent": -12, "runs": [{ "text": "Render every slide", "style": { "fontSize": 18, "color": "#334155" } }] }
          ]
        },
        {
          "name": "delivery-card",
          "geometry": "roundRect",
          "position": { "left": 876, "top": 150, "width": 330, "height": 150 },
          "fill": "#F3E8FF",
          "line": { "fill": "#7C3AED", "width": 2 },
          "shadow": { "color": "#000000", "blurRadius": 7, "distance": 3, "direction": 45, "opacity": 0.18 },
          "text": [
            { "runs": [{ "text": "Delivery", "style": { "fontSize": 27, "bold": true, "color": "#581C87" } }] },
            { "bulletCharacter": "•", "marginLeft": 24, "indent": -12, "runs": [{ "text": "Export only after QA", "style": { "fontSize": 18, "color": "#334155" } }] }
          ]
        }
      ],
      "connectors": [
        {
          "name": "semantic-to-visual",
          "connectorType": "straight",
          "fromName": "semantic-card",
          "toName": "visual-card",
          "start": { "x": 402, "y": 225 },
          "end": { "x": 474, "y": 225 },
          "line": { "fill": "#475569", "width": 2, "endArrow": "triangle" }
        },
        {
          "name": "visual-to-delivery",
          "connectorType": "straight",
          "fromName": "visual-card",
          "toName": "delivery-card",
          "start": { "x": 804, "y": 225 },
          "end": { "x": 876, "y": 225 },
          "line": { "fill": "#475569", "width": 2, "endArrow": "triangle" }
        }
      ],
      "tables": [
        {
          "name": "review-evidence",
          "position": { "left": 72, "top": 390, "width": 520, "height": 200 },
          "values": [["Evidence", "Required"], ["Package", "Yes"], ["Full-size render", "Yes"]],
          "styleOptions": { "headerRow": true, "bandedRows": true }
        }
      ],
      "images": [
        {
          "name": "review-status",
          "alt": "Green review status",
          "position": { "left": 720, "top": 390, "width": 200, "height": 200 },
          "fit": "stretch",
          "dataUrl": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAusB9Wl2nGQAAAAASUVORK5CYII="
        }
      ]
    }
  ],
  "expectInspect": [
    { "kind": "shape", "pattern": "Review semantic and visual evidence" },
    { "kind": "table", "pattern": "review-evidence" },
    { "kind": "image", "pattern": "Green review status" },
    { "kind": "connector", "pattern": "visual-to-delivery" }
  ],
  "qa": {
    "nativeRender": "auto",
    "inspectKind": "deck,slide,textbox,shape,table,image,connector,textRange",
    "maxChars": 18000
  }
}
