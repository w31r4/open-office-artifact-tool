{
  "name": "modern-comments",
  "outputName": "modern-comments.pptx",
  "commentFormat": "modern",
  "slideSize": { "width": 1280, "height": 720 },
  "theme": {
    "name": "Modern Review",
    "colors": { "accent1": "#2563eb", "accent2": "#16a34a", "tx1": "#0f172a", "bg1": "#ffffff" }
  },
  "layouts": [
    { "id": "modern-blank", "name": "Modern Blank", "type": "blank", "masterId": "master/default" }
  ],
  "slides": [
    {
      "name": "office-2021-review",
      "layoutId": "modern-blank",
      "shapes": [
        {
          "name": "review-title",
          "text": "Office 2021 comments survive agent roundtrip",
          "position": { "left": 72, "top": 64, "width": 1060, "height": 90 },
          "fill": "transparent",
          "line": { "fill": "transparent", "width": 0 },
          "textStyle": { "fontSize": 40, "bold": true, "color": "#0f172a" }
        }
      ],
      "groups": [
        {
          "name": "review-evidence-group",
          "position": { "left": 72, "top": 220, "width": 1050, "height": 300 },
          "childFrame": { "left": 0, "top": 0, "width": 1050, "height": 300 },
          "shapes": [
            {
              "name": "review-evidence",
              "text": "GUID authors  •  native replies  •  text and group anchors  •  relationship-owned parts",
              "position": { "left": 0, "top": 0, "width": 1050, "height": 96 },
              "fill": "#dbeafe",
              "line": { "fill": "#2563eb", "width": 2 },
              "textStyle": { "fontSize": 27, "color": "#1e3a8a" }
            }
          ],
          "tables": [
            {
              "name": "review-table",
              "position": { "left": 0, "top": 116, "width": 290, "height": 150 },
              "values": [["Node", "Anchor"], ["Table", "graphicFrameMk"], ["Image", "picMk"]],
              "rows": 3,
              "columns": 2,
              "styleOptions": { "headerRow": true, "bandedRows": true }
            }
          ],
          "charts": [
            {
              "name": "review-chart",
              "chartType": "bar",
              "title": "Grouped parts",
              "position": { "left": 320, "top": 108, "width": 450, "height": 174 },
              "categories": ["Shape", "Table", "Chart", "Image"],
              "series": [{ "name": "Validated", "values": [1, 1, 1, 1], "color": "#2563eb" }],
              "legend": false
            }
          ],
          "images": [
            {
              "name": "review-image",
              "alt": "Grouped picture relationship",
              "position": { "left": 820, "top": 132, "width": 120, "height": 120 },
              "dataUrl": "data:image/png;base64,"
            }
          ]
        }
      ],
      "comments": [
        {
          "targetName": "review-title",
          "targetTextRange": true,
          "author": "QA Agent",
          "created": "2026-07-13T01:02:03Z",
          "text": "Validate the Office 2021 comment graph.",
          "replies": [
            { "author": "Maintainer", "created": "2026-07-13T02:03:04Z", "text": "Authors, GUIDs, reply nesting, and status verified." }
          ],
          "resolved": true
        },
        {
          "targetName": "review-evidence-group",
          "author": "QA Agent",
          "created": "2026-07-13T03:04:05Z",
          "text": "Validate the native group-shape anchor."
        },
        {
          "targetName": "review-table",
          "author": "QA Agent",
          "created": "2026-07-13T04:05:06Z",
          "text": "Validate the grouped table graphic-frame anchor."
        },
        {
          "targetName": "review-chart",
          "author": "QA Agent",
          "created": "2026-07-13T05:06:07Z",
          "text": "Validate the grouped chart graphic-frame anchor."
        },
        {
          "targetName": "review-image",
          "author": "QA Agent",
          "created": "2026-07-13T06:07:08Z",
          "text": "Validate the grouped picture anchor."
        }
      ]
    }
  ],
  "expectInspect": [
    { "kind": "comment", "pattern": "Office 2021 comment graph" },
    { "kind": "shape", "pattern": "GUID authors" },
    { "kind": "groupShape", "pattern": "review-evidence-group" },
    { "kind": "table", "pattern": "graphicFrameMk" },
    { "kind": "chart", "pattern": "Grouped parts" },
    { "kind": "image", "pattern": "Grouped picture" }
  ],
  "qa": {
    "nativeRender": "auto",
    "inspectKind": "deck,slide,shape,groupShape,table,chart,image,comment,textRange",
    "maxChars": 16000
  }
}
