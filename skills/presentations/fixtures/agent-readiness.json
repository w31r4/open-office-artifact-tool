{
  "name": "agent-readiness",
  "outputName": "agent-readiness.pptx",
  "slideSize": { "width": 1280, "height": 720 },
  "theme": {
    "name": "Grid Clean Room",
    "colors": { "accent1": "#3D8DFF", "accent2": "#6DCBF4", "accent3": "#16A34A", "bg1": "#FFFFFF", "tx1": "#000000" },
    "fonts": { "major": "Arial", "minor": "Arial" }
  },
  "layouts": [
    { "id": "layout/blank-grid", "name": "Blank Grid", "type": "blank", "masterId": "master/agent-readiness", "placeholders": [] }
  ],
  "slides": [
    {
      "name": "Opening",
      "layoutId": "layout/blank-grid",
      "background": "#FFFFFF",
      "notes": "Open by framing the deck as evidence that agent-facing PPTX work can be independently implemented and verified.",
      "shapes": [
        { "name": "cover-kicker", "position": { "left": 42, "top": 42, "width": 600, "height": 52 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "OPEN OFFICE ARTIFACT TOOL", "textStyle": { "fontSize": 24, "bold": true, "color": "#3D8DFF" } },
        { "name": "cover-title", "position": { "left": 42, "top": 184, "width": 1196, "height": 220 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "PPTX workflows now close the QA loop", "textStyle": { "fontSize": 54, "bold": true, "color": "#000000" } },
        { "name": "cover-subtitle", "position": { "left": 42, "top": 500, "width": 1000, "height": 92 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "Create, inspect, roundtrip, render, and verify through public clean-room APIs.", "textStyle": { "fontSize": 26, "color": "#000000" } }
      ],
      "images": [
        { "name": "verified-mark", "alt": "Verified clean-room workflow", "position": { "left": 1130, "top": 42, "width": 72, "height": 72 }, "fit": "contain", "dataUrl": "data:image/png;base64," }
      ]
    },
    {
      "name": "Native structure",
      "layoutId": "layout/blank-grid",
      "background": "#FFFFFF",
      "notes": "Use the table to distinguish facade evidence from native OOXML package evidence.",
      "shapes": [
        { "name": "structure-title", "position": { "left": 42, "top": 36, "width": 1196, "height": 80 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "Native PPTX parts preserve agent-visible structure", "textStyle": { "fontSize": 42, "bold": true, "color": "#000000" } },
        { "name": "structure-lead", "position": { "left": 42, "top": 126, "width": 1196, "height": 54 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "Each gate leaves bounded evidence an agent can inspect and resolve.", "textStyle": { "fontSize": 20, "color": "#334155" } },
        { "name": "structure-footer", "position": { "left": 1160, "top": 648, "width": 78, "height": 48 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "02", "textStyle": { "fontSize": 16, "color": "#64748B" } }
      ],
      "tables": [
        { "name": "evidence-table", "position": { "left": 42, "top": 220, "width": 1196, "height": 370 }, "rows": 4, "columns": 4, "styleOptions": { "headerRow": true }, "values": [["Gate", "Public API", "Native evidence", "Result"], ["Semantic", "inspect + resolve", "stable objects", "Pass"], ["Package", "inspectPptx", "slides, charts, media", "Pass"], ["Visual", "verify + render", "page PNG baseline", "Required"]] }
      ],
      "comments": [
        { "targetName": "structure-title", "author": "QA Agent", "text": "Confirm all native parts survive roundtrip before delivery.", "replies": [{ "author": "Maintainer", "text": "Verified through package inspection." }], "resolved": true }
      ]
    },
    {
      "name": "Verification loop",
      "layoutId": "layout/blank-grid",
      "background": "#FFFFFF",
      "notes": "Close by showing that semantic, package, and visual gates are cumulative rather than interchangeable.",
      "shapes": [
        { "name": "qa-title", "position": { "left": 42, "top": 36, "width": 1196, "height": 80 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "Three gates turn a PPTX into evidence", "textStyle": { "fontSize": 42, "bold": true, "color": "#000000" } },
        { "name": "semantic-callout", "position": { "left": 680, "top": 160, "width": 520, "height": 120 }, "fill": "#EDEDED", "line": { "fill": "#B8BCC4", "width": 1 }, "text": "Semantic gate catches broken structure", "textStyle": { "fontSize": 24, "bold": true, "color": "#000000" } },
        { "name": "package-callout", "position": { "left": 680, "top": 330, "width": 520, "height": 120 }, "fill": "#EDEDED", "line": { "fill": "#B8BCC4", "width": 1 }, "text": "Package gate proves native parts exist", "textStyle": { "fontSize": 24, "bold": true, "color": "#000000" } },
        { "name": "visual-callout", "position": { "left": 680, "top": 500, "width": 520, "height": 120 }, "fill": "#EDEDED", "line": { "fill": "#B8BCC4", "width": 1 }, "text": "Visual gate catches what XML cannot", "textStyle": { "fontSize": 24, "bold": true, "color": "#000000" } },
        { "name": "qa-footer", "position": { "left": 1160, "top": 648, "width": 78, "height": 48 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "03", "textStyle": { "fontSize": 16, "color": "#64748B" } }
      ],
      "charts": [
        { "chartType": "bar", "name": "coverage-chart", "title": "Evidence produced per gate", "position": { "left": 42, "top": 150, "width": 560, "height": 500 }, "categories": ["Semantic", "Package", "Visual"], "axes": { "category": { "title": "Gate" }, "value": { "title": "Evidence records" } }, "legend": { "visible": true, "position": "b" }, "dataLabels": { "showValue": true }, "series": [{ "name": "Modeled", "values": [8, 2, 3], "color": "#6DCBF4" }, { "name": "Native", "values": [2, 9, 6], "color": "#3D8DFF" }] }
      ],
      "connectors": [
        { "name": "chart-to-semantic", "start": { "x": 602, "y": 280 }, "end": { "x": 680, "y": 220 }, "line": { "fill": "#3D8DFF", "width": 2, "endArrow": "triangle" } }
      ],
      "comments": [
        { "targetName": "visual-callout", "author": "QA Agent", "text": "Inspect every rendered slide at full size." }
      ]
    }
  ],
  "expectInspect": [
    { "kind": "slide,textbox", "pattern": "PPTX workflows now close the QA loop" },
    { "kind": "table", "pattern": "evidence-table" },
    { "kind": "chart", "pattern": "Evidence produced per gate" },
    { "kind": "image", "pattern": "Verified clean-room workflow" },
    { "kind": "connector", "pattern": "chart-to-semantic" },
    { "kind": "notes", "pattern": "cumulative rather than interchangeable" },
    { "kind": "comment", "pattern": "Inspect every rendered slide" }
  ],
  "qa": {
    "nativeRender": "auto",
    "inspectKind": "deck,theme,layout,slide,textbox,shape,table,chart,image,connector,notes,comment,textRange",
    "maxChars": 30000
  }
}
