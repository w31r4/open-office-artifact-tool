{
  "name": "agent-readiness",
  "outputName": "agent-readiness.pptx",
  "slideSize": { "width": 1280, "height": 720 },
  "theme": {
    "name": "Grid Clean Room",
    "colors": { "accent1": "#3D8DFF", "accent2": "#6DCBF4", "accent3": "#16A34A", "accent4": "#7C3AED", "accent5": "#F97316", "accent6": "#DC2626", "bg1": "#FFFFFF", "tx1": "#000000", "bg2": "#F8FAFC", "tx2": "#334155", "hlink": "#2563EB", "folHlink": "#9333EA" },
    "fonts": { "major": "Arial", "minor": "Arial", "majorEastAsia": "PingFang SC", "majorComplexScript": "Arial", "minorEastAsia": "Noto Sans CJK SC", "minorComplexScript": "Arial" },
    "textStyles": {
      "title": { "fontSize": 42, "bold": true, "color": "accent1", "fontFamily": "+mj-lt", "alignment": "left" },
      "body": { "fontSize": 20, "color": "tx2", "fontFamily": "+mn-lt", "alignment": "left" },
      "other": { "fontSize": 16, "color": "#475569", "fontFamily": "+mn-lt", "alignment": "left" }
    },
    "colorMap": { "accent1": "accent2", "accent2": "accent1" }
  },
  "masters": [
    {
      "id": "master/agent-readiness",
      "name": "Agent Readiness Master",
      "background": { "fill": "bg1", "mode": "reference", "index": 1001 },
      "textParagraphStyles": {
        "body": {
          "0": { "bulletCharacter": "•", "bulletFont": "Arial", "bulletColor": "accent1", "bulletSizePercent": 1.1, "marginLeft": 28, "indent": -14, "spaceAfter": 4, "style": { "fontSize": 20, "color": "tx2" } },
          "1": { "bulletCharacter": "–", "bulletFont": "Arial", "bulletColor": "tx2", "bulletSize": 18, "marginLeft": 52, "indent": -18, "spaceBeforePercent": 0.2, "style": { "fontSize": 18, "color": "tx2" } },
          "2": { "bulletImage": { "dataUrl": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAYAAAAf8/9hAAAACXBIWXMAAAPoAAAD6AG1e1JrAAAAHUlEQVR4nGNQOhr3nxLMMGrA/9EwiBsNg6PDIgwAUQdEH39xn2wAAAAASUVORK5CYII=", "alt": "Inherited package evidence" }, "bulletSize": 16, "marginLeft": 72, "indent": -20, "style": { "fontSize": 18, "color": "tx2" } }
        }
      },
      "placeholders": [
        { "id": "master/agent-readiness/title", "type": "title", "idx": 1, "name": "structure-title", "position": { "left": 42, "top": 36, "width": 1196, "height": 80 }, "text": "Native PPTX parts preserve agent-visible structure", "required": true, "style": { "fontSize": 42, "bold": true, "color": "accent1", "fontFamily": "+mj-lt" } }
      ]
    },
    {
      "id": "master/verification",
      "name": "Verification Master",
      "background": { "fill": "accent1", "mode": "reference", "index": 1001 },
      "theme": {
        "name": "Verification Theme",
        "colors": { "accent1": "#EDE9FE", "accent2": "#7C3AED" },
        "fonts": { "major": "Georgia" },
        "textStyles": { "title": { "fontSize": 40, "color": "accent2" } },
        "colorMap": { "accent1": "accent1", "accent2": "accent2" }
      },
      "placeholders": [
        { "id": "master/verification/title", "type": "title", "idx": 1, "name": "Verification Title", "position": { "left": 42, "top": 36, "width": 1196, "height": 80 }, "required": true, "style": { "fontSize": 40, "bold": true, "color": "accent2", "fontFamily": "+mj-lt" } }
      ]
    }
  ],
  "layouts": [
    { "id": "layout/blank-grid", "name": "Blank Grid", "type": "blank", "masterId": "master/agent-readiness", "background": "#FFFFFF", "placeholders": [{ "type": "body", "idx": 2, "name": "Inherited Package Evidence", "position": { "left": 42, "top": 604, "width": 760, "height": 42 }, "text": [{ "level": 2, "runs": ["Master-owned picture bullet survives template inheritance"] }] }] },
    { "id": "layout/verification-grid", "name": "Verification Grid", "type": "blank", "masterId": "master/verification", "placeholders": [] }
  ],
  "slides": [
    {
      "name": "Opening",
      "layoutId": "layout/verification-grid",
      "notes": "Open by framing the deck as evidence that agent-facing PPTX work can be independently implemented and verified.",
      "shapes": [
        { "name": "cover-kicker", "position": { "left": 42, "top": 42, "width": 600, "height": 52 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "OPEN OFFICE ARTIFACT TOOL", "textStyle": { "fontSize": 24, "bold": true, "color": "#3D8DFF" } },
        { "name": "cover-title", "position": { "left": 42, "top": 184, "width": 1196, "height": 220 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "PPTX workflows now close the QA loop", "textStyle": { "fontSize": 54, "bold": true, "color": "#000000" } },
        { "name": "cover-subtitle", "position": { "left": 42, "top": 500, "width": 1000, "height": 92 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "Create, inspect, roundtrip, render, and verify through public clean-room APIs.", "textStyle": { "fontSize": 26, "color": "#000000" } }
      ],
      "images": [
        { "name": "verified-mark", "alt": "Verified clean-room workflow", "position": { "left": 1130, "top": 42, "width": 72, "height": 72 }, "fit": "contain", "dataUrl": "data:image/png;base64," }
      ]
    },
    {
      "name": "Native structure",
      "layoutId": "layout/blank-grid",
      "applyLayoutPlaceholders": true,
      "background": "#FFFFFF",
      "notes": "Use the table to distinguish facade evidence from native OOXML package evidence.",
      "shapes": [
        { "name": "structure-lead", "position": { "left": 42, "top": 126, "width": 1196, "height": 54 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "Each gate leaves bounded evidence an agent can inspect and resolve.", "textStyle": { "fontSize": 20, "color": "#334155" } },
        { "name": "structure-footer", "position": { "left": 1160, "top": 648, "width": 78, "height": 48 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "02", "textStyle": { "fontSize": 16, "color": "#64748B" } }
      ],
      "tables": [
        { "name": "evidence-table", "position": { "left": 42, "top": 220, "width": 1196, "height": 370 }, "rows": 4, "columns": 4, "styleOptions": { "headerRow": true }, "values": [["Gate", "Public API", "Native evidence", "Result"], ["Semantic", "inspect + resolve", "stable objects", "Pass"], ["Package", "inspectPptx", "slides, charts, media", "Pass"], ["Visual", "verify + render", "page PNG baseline", "Required"]] }
      ],
      "comments": [
        { "targetName": "structure-title", "author": "QA Agent", "text": "Confirm all native parts survive roundtrip before delivery.", "replies": [{ "author": "Maintainer", "text": "Verified through package inspection." }], "resolved": true }
      ]
    },
    {
      "name": "Verification loop",
      "layoutId": "layout/blank-grid",
      "background": "#FFFFFF",
      "notes": "Close by showing that semantic, package, and visual gates are cumulative rather than interchangeable.",
      "shapes": [
        { "name": "qa-title", "position": { "left": 42, "top": 36, "width": 1196, "height": 80 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "Three gates turn a PPTX into evidence", "textStyle": { "fontSize": 42, "bold": true, "color": "#000000" } },
        { "name": "semantic-callout", "position": { "left": 680, "top": 160, "width": 520, "height": 120 }, "fill": "#EDEDED", "line": { "fill": "#B8BCC4", "width": 1 }, "text": [{ "runs": [{ "run": "Semantic gate", "textStyle": { "bold": true } }] }, { "bulletCharacter": "◆", "bulletFont": "Georgia", "bulletColor": "#DC2626", "bulletSizePercent": 1.25, "marginLeft": 24, "indent": -12, "runs": ["catches broken structure"] }], "textStyle": { "fontSize": 24, "color": "#000000" } },
        { "name": "package-callout", "position": { "left": 680, "top": 330, "width": 520, "height": 120 }, "fill": "#EDEDED", "line": { "fill": "#B8BCC4", "width": 1 }, "text": [{ "runs": [{ "run": "Package gate", "textStyle": { "bold": true } }] }, { "bulletImage": { "dataUrl": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAYAAAAf8/9hAAAACXBIWXMAAAPoAAAD6AG1e1JrAAAAHUlEQVR4nGNQOhr3nxLMMGrA/9EwiBsNg6PDIgwAUQdEH39xn2wAAAAASUVORK5CYII=", "alt": "Package evidence" }, "bulletSize": 18, "marginLeft": 26, "indent": -20, "runs": ["proves native parts exist"] }], "textStyle": { "fontSize": 24, "color": "#000000" } },
        { "name": "visual-callout", "position": { "left": 680, "top": 500, "width": 520, "height": 120 }, "fill": "#EDEDED", "line": { "fill": "#B8BCC4", "width": 1 }, "text": "Visual gate catches what XML cannot", "textStyle": { "fontSize": 24, "bold": true, "color": "#000000" } },
        { "name": "qa-footer", "position": { "left": 1160, "top": 648, "width": 78, "height": 48 }, "fill": "transparent", "line": { "fill": "transparent", "width": 0 }, "text": "03", "textStyle": { "fontSize": 16, "color": "#64748B" } }
      ],
      "charts": [
        { "chartType": "bar", "name": "coverage-chart", "title": "Evidence produced per gate", "position": { "left": 42, "top": 150, "width": 560, "height": 500 }, "categories": ["Semantic", "Package", "Visual"], "styleId": 10, "varyColors": true, "barOptions": { "direction": "bar", "grouping": "stacked", "gapWidth": 80, "overlap": -20 }, "axes": { "category": { "title": "Gate" }, "value": { "title": "Evidence records" } }, "legend": { "visible": true, "position": "b" }, "dataLabels": { "showValue": true }, "series": [{ "name": "Modeled", "values": [8, 2, 3], "color": "#6DCBF4", "line": { "fill": "#0369A1", "width": 1.5, "style": "dash" } }, { "name": "Native", "values": [2, 9, 6], "color": "#3D8DFF", "points": [{ "idx": 1, "fill": "#FACC15", "line": { "fill": "#DC2626", "width": 2, "style": "dot" } }] }] }
      ],
      "connectors": [
        { "name": "chart-to-semantic", "start": { "x": 602, "y": 280 }, "end": { "x": 680, "y": 220 }, "line": { "fill": "#3D8DFF", "width": 2, "endArrow": "triangle" } }
      ],
      "comments": [
        { "targetName": "visual-callout", "author": "QA Agent", "text": "Inspect every rendered slide at full size." }
      ]
    }
  ],
  "expectInspect": [
    { "kind": "slideMaster", "pattern": "Verification Master" },
    { "kind": "slide,textbox", "pattern": "PPTX workflows now close the QA loop" },
    { "kind": "table", "pattern": "evidence-table" },
    { "kind": "chart", "pattern": "Evidence produced per gate" },
    { "kind": "image", "pattern": "Verified clean-room workflow" },
    { "kind": "connector", "pattern": "chart-to-semantic" },
    { "kind": "notes", "pattern": "cumulative rather than interchangeable" },
    { "kind": "comment", "pattern": "Inspect every rendered slide" }
  ],
  "qa": {
    "nativeRender": "auto",
    "inspectKind": "deck,theme,slideMaster,layout,slide,textbox,shape,table,chart,image,connector,notes,comment,textRange",
    "maxChars": 30000
  }
}
