{
  "name": "qa-report",
  "outputName": "qa-report.pdf",
  "metadata": { "title": "Office artifact QA report", "author": "open-office-artifact-tool" },
  "pages": [
    {
      "width": 612,
      "height": 792,
      "text": "Office artifact QA report\nSemantic and visual evidence agree",
      "textItems": [
        { "text": "Agent-ready evidence", "bbox": [72, 142, 240, 20], "fontName": "Helvetica", "fontSize": 18, "color": "#16a34a", "bold": true },
        { "text": "Page 1 of 2", "bbox": [470, 752, 80, 12], "fontName": "Helvetica", "fontSize": 10, "color": "#64748b" }
      ],
      "regions": [
        { "kind": "titleBand", "label": "Report heading", "bbox": [72, 72, 468, 96] },
        { "kind": "evidenceTable", "label": "QA gates", "bbox": [72, 190, 468, 128] }
      ],
      "tables": [
        { "name": "qa-gates", "bbox": [72, 190, 468, 128], "values": [["Gate", "Public evidence", "Result"], ["Semantic", "inspect + verify", "Pass"], ["Package", "file objects", "Pass"], ["Visual", "page PNG baseline", "Required"]] }
      ],
      "images": [
        { "name": "verified-mark", "alt": "Verified workflow", "bbox": [500, 72, 40, 40], "fit": "contain", "dataUrl": "data:image/png;base64," }
      ],
      "charts": [
        { "name": "evidence-chart", "title": "Evidence produced per gate", "chartType": "bar", "bbox": [72, 380, 468, 230], "categories": ["Semantic", "Package", "Visual"], "series": [{ "name": "Modeled", "values": [8, 2, 3], "color": "#6DCBF4" }, { "name": "Native", "values": [2, 9, 6], "color": "#3D8DFF" }] }
      ]
    },
    {
      "width": 612,
      "height": 792,
      "text": "Extraction remains independently verifiable\nParser evidence complements visual review",
      "textItems": [
        { "text": "PDF.js and Poppler agree", "bbox": [72, 142, 260, 20], "fontName": "Helvetica", "fontSize": 18, "color": "#2563eb", "bold": true },
        { "text": "Page 2 of 2", "bbox": [470, 752, 80, 12], "fontName": "Helvetica", "fontSize": 10, "color": "#64748b" }
      ],
      "regions": [
        { "kind": "titleBand", "label": "Extraction heading", "bbox": [72, 72, 468, 96] },
        { "kind": "parserTable", "label": "Parser evidence", "bbox": [72, 200, 468, 140] }
      ],
      "tables": [
        { "name": "parser-evidence", "bbox": [72, 200, 468, 140], "values": [["Path", "Evidence", "Use"], ["Metadata", "stable model", "roundtrip"], ["PDF.js", "text geometry", "extraction"], ["Poppler", "page pixels", "visual QA"]] }
      ],
      "charts": [
        { "name": "parser-chart", "title": "Independent checks accumulate", "chartType": "line", "bbox": [72, 410, 468, 210], "categories": ["Model", "Parser", "Raster"], "series": [{ "name": "Confidence", "values": [3, 6, 9], "color": "#16a34a" }] }
      ]
    }
  ],
  "expectInspect": [
    { "kind": "page,text", "pattern": "Office artifact QA report" },
    { "kind": "textItem", "pattern": "PDF.js and Poppler agree" },
    { "kind": "table", "pattern": "qa-gates" },
    { "kind": "image", "pattern": "Verified workflow" },
    { "kind": "chart", "pattern": "Independent checks accumulate" },
    { "kind": "region", "pattern": "Parser evidence" }
  ],
  "expectText": ["Office artifact QA report", "Parser evidence complements visual review"],
  "expectPdfjsText": ["Office artifact QA report", "PDF.js and Poppler agree", "Independent checks accumulate"],
  "qa": { "nativeRender": "auto", "pdfjs": "auto", "inspectKind": "page,text,textItem,region,table,image,chart", "maxChars": 30000 }
}
