{
  "name": "business-brief",
  "outputName": "business-brief.docx",
  "designPreset": "report",
  "theme": {
    "name": "Business Brief Theme",
    "colors": { "accent1": "#336699", "accent2": "#cc3300" },
    "fonts": { "major": "Source Serif 4", "minor": "Aptos", "majorEastAsia": "Arial Unicode MS", "majorComplexScript": "Geeza Pro" }
  },
  "defaultRunStyle": { "fontFamily": "Default Serif", "fontSize": 19, "italic": true },
  "styles": {
    "BriefParagraphBase": { "name": "Brief Paragraph Base", "basedOn": "Normal", "fontSize": 26, "bold": true },
    "BriefParagraph": { "name": "Brief Paragraph", "basedOn": "BriefParagraphBase", "themeColor": "accent1" },
    "BriefCharacterBase": { "name": "Brief Character Base", "type": "character", "italic": true, "themeColor": "accent2" },
    "BriefCharacter": { "name": "Brief Character", "type": "character", "basedOn": "BriefCharacterBase", "bold": false, "fontTheme": "majorHAnsi" }
  },
  "headers": [
    { "name": "inherited-header", "text": "Clean-room document workflow", "sectionIndex": 0 }
  ],
  "footers": [
    { "name": "inherited-footer", "text": "Internal QA fixture", "sectionIndex": 0 }
  ],
  "blocks": [
    { "kind": "paragraph", "name": "title", "styleId": "Title", "text": "Office artifact readiness brief" },
    { "kind": "paragraph", "name": "lead", "styleId": "Normal", "text": "This brief verifies an agent can create, inspect, render, and validate a real DOCX." },
    { "kind": "paragraph", "name": "theme-runs", "styleId": "Normal", "runs": [
      { "text": "Theme fidelity ", "style": { "fontTheme": "majorHAnsi", "themeColor": "accent1", "themeTint": "80", "bold": true, "boldComplexScript": false, "fontSize": 28, "fontSizeComplexScript": 34 } },
      { "text": "East Asia", "style": { "fontTheme": "minorHAnsi", "fontFamilyEastAsia": "Arial Unicode MS", "fontThemeEastAsia": "majorEastAsia" } }
    ] },
    { "kind": "paragraph", "name": "theme-complex-run", "styleId": "Normal", "runs": [
      { "text": "العربية", "style": { "fontTheme": "minorHAnsi", "fontFamilyComplexScript": "Geeza Pro", "fontThemeComplexScript": "majorBidi", "bold": false, "boldComplexScript": true, "italic": false, "italicComplexScript": true, "fontSize": 22, "fontSizeComplexScript": 32 } }
    ] },
    { "kind": "paragraph", "name": "inherited-run-style", "styleId": "BriefParagraph", "runs": [
      { "text": "Inherited character style", "style": { "runStyleId": "BriefCharacter", "italic": false } }
    ] },
    { "kind": "hyperlink", "name": "recommendation-jump", "styleId": "Normal", "text": "Jump to recommendation", "anchor": "RecommendationSection", "tooltip": "Open the recommendation section", "history": false },
    { "kind": "paragraph", "name": "recommendation-heading", "styleId": "Heading1", "text": "Recommendation" },
    { "kind": "paragraph", "name": "recommendation", "styleId": "Normal", "text": "Use semantic verification together with native page rendering before delivery." },
    { "kind": "listItem", "name": "semantic-step", "styleId": "Normal", "listType": "bullet", "text": "Inspect stable document blocks and comments." },
    { "kind": "listItem", "name": "render-step", "styleId": "Normal", "listType": "bullet", "text": "Render the exported DOCX through LibreOffice and Poppler." },
    { "kind": "listItem", "name": "lettered-step", "styleId": "Normal", "listType": "number", "numberFormat": "upperLetter", "start": 2, "levelText": "%1)", "numberingId": 77, "text": "Preserve native numbering definitions." },
    { "kind": "listItem", "name": "roman-substep", "styleId": "Normal", "listType": "number", "level": 1, "numberFormat": "lowerRoman", "start": 3, "levelText": "%1.%2)", "numberingId": 77, "text": "Resolve nested numbering levels." },
    { "kind": "section", "name": "evidence-section", "breakType": "nextPage", "orientation": "portrait" },
    {
      "kind": "table",
      "name": "readiness-table",
      "styleId": "TableGrid",
      "widthDxa": 9360,
      "indentDxa": 120,
      "columnWidthsDxa": [1800, 5160, 2400],
      "headerFill": "F2F4F7",
      "values": [
        ["Gate", "Evidence", "Status"],
        ["Semantic", "inspect + verify", "Pass"],
        ["Package", "DOCX parts", "Pass"],
        ["Visual", "page PNG", "Required"]
      ]
    },
    { "kind": "hyperlink", "name": "readiness-jump", "styleId": "Normal", "text": "Jump to readiness evidence", "url": "#ReadinessEvidence", "tooltip": "Open the readiness table evidence", "history": false },
    { "kind": "hyperlink", "name": "standards-link", "styleId": "Normal", "text": "OOXML overview", "url": "https://learn.microsoft.com/office/open-xml/open-xml-sdk" },
    { "kind": "citation", "name": "source-note", "styleId": "Normal", "text": "Source: ECMA-376 Office Open XML", "metadata": { "source": "ECMA-376", "url": "https://ecma-international.org/publications-and-standards/standards/ecma-376/" } },
    { "kind": "image", "name": "status-mark", "styleId": "Normal", "alt": "Green status mark", "widthPx": 40, "heightPx": 40, "dataUrl": "data:image/png;base64," },
    { "kind": "field", "name": "page-number", "styleId": "Normal", "instruction": "PAGE", "display": "1" }
  ],
  "bookmarks": [
    { "name": "RecommendationSection", "targetName": "recommendation-heading", "endTargetName": "recommendation", "nativeId": 42 },
    { "name": "ReadinessEvidence", "targetName": "readiness-table", "targetCell": [1, 0], "endTargetName": "readiness-table", "endTargetCell": [3, 2], "nativeId": 43 }
  ],
  "comments": [
    { "name": "recommendation-review", "targetName": "recommendation-heading", "author": "QA Agent", "initials": "QA", "date": "2026-07-11T00:20:00.000Z", "dateUtc": "2026-07-11T08:20:00+08:00", "durableId": "0010A001", "person": { "providerId": "None", "userId": "qa-agent@example.test" }, "resolved": true, "text": "Confirm this recommendation after native render review." },
    { "name": "recommendation-reply", "parentName": "recommendation-review", "author": "Maintainer", "initials": "MT", "date": "2026-07-11T00:22:00.000Z", "durableId": "0010A002", "person": { "providerId": "None", "userId": "maintainer@example.test" }, "text": "Recommendation wording is approved." },
    { "targetName": "readiness-table", "author": "Maintainer", "initials": "MT", "date": "2026-07-11T00:25:00.000Z", "person": { "providerId": "None", "userId": "maintainer@example.test" }, "text": "Confirm the table comment anchor survives native import." }
  ],
  "expectInspect": [
    { "kind": "paragraph", "pattern": "Office artifact readiness brief" },
    { "kind": "paragraph", "pattern": "Theme fidelity" },
    { "kind": "paragraph", "pattern": "Inherited character style" },
    { "kind": "hyperlink", "pattern": "RecommendationSection" },
    { "kind": "bookmark", "pattern": "RecommendationSection" },
    { "kind": "bookmark", "pattern": "ReadinessEvidence" },
    { "kind": "listItem", "pattern": "LibreOffice and Poppler" },
    { "kind": "listItem", "pattern": "nested numbering levels" },
    { "kind": "table", "pattern": "readiness-table" },
    { "kind": "comment", "pattern": "native render review" },
    { "kind": "comment", "pattern": "wording is approved" },
    { "kind": "header", "pattern": "Clean-room document workflow" },
    { "kind": "comment", "pattern": "table comment anchor" }
  ],
  "qa": {
    "previewFormat": "svg",
    "nativeRender": "auto",
    "inspectKind": "document,theme,paragraph,listItem,table,bookmark,comment,header,footer,hyperlink,field,citation,image,style,layout",
    "maxChars": 24000
  }
}
