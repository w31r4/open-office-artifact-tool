          "title": "Quarter performance",
          "topLeft": "I2",
          "bottomRight": "M10"
        }
      ],
      "pivots": [
        {
          "name": "RevenuePivot",
          "sourceRange": "A1:E4",
          "targetRange": "I18:J22",
          "groupFields": [
            { "name": "Period Year", "sourceField": "Period End", "groupBy": "years" },
            { "name": "Period Quarter", "sourceField": "Period End", "groupBy": "quarters" },
            { "name": "Period Month", "sourceField": "Period End", "groupBy": "months" }
          ],
          "rowFields": ["Period Year", "Period Quarter", "Period Month", "Month", "Period End"],
          "filters": [
            { "field": "Month", "include": ["Jan", "Mar"] },
            { "field": "Period End", "type": "dateBetween", "value1": "2026-03-31T17:00:00Z", "value2": "2026-03-31T19:00:00Z", "useWholeDay": false }
          ],
          "refreshPolicy": {
            "refreshOnLoad": false,
            "saveData": true,
            "enableRefresh": true,
            "missingItemsLimit": 2,
            "refreshedBy": "Spreadsheet skill",
            "refreshedDateIso": "2026-07-12T00:00:00Z"
          },
          "calculatedFields": [
            { "name": "Margin Rate", "formula": "=IF(AND(ISNUMBER([Revenue]),[Revenue]>=[Cost],LEN(TRIM(\"  ok  \"))=2,UPPER(LEFT(\"pass\",1))=\"P\",LOWER(RIGHT(\"OK\",1))=\"k\",MID(\"margin\",2,2)=\"ar\"),IFERROR(ROUND(SQRT(POWER([Revenue]-[Cost],2))/[Revenue],2),0),0)" },
            { "name": "Date Contract", "formula": "=IF(AND(DATE(1904,1,1)=0,YEAR(DATE(2026,3,31))=2026,MONTH(DATE(2026,3,31))=3,DAY(DATE(2026,3,31))=31),[Revenue]-[Cost],0)" },
            { "name": "Date Shift Contract", "formula": "=IF(AND(DAY(EDATE(DATE(2024,1,31),1))=29,DAY(EOMONTH(DATE(2024,2,10),0))=29,DAYS(DATE(2024,3,1),DATE(2024,2,28))=2,WEEKDAY(DATE(2026,3,31),2)=2),[Revenue]-[Cost],0)" },
            { "name": "Time Contract", "formula": "=IF(AND(HOUR(TIME(27,0,0))=3,MINUTE(TIME(0,750,0))=30,SECOND(TIME(0,0,2000))=20,HOUR(DATE(2026,3,31)+TIME(18,45,30))=18),[Revenue]-[Cost],0)" }
          ],
          "valueFields": [
            { "field": "Revenue", "summarizeBy": "sum", "name": "Revenue total" },
            { "field": "Margin Rate", "name": "Margin rate" },
            { "field": "Date Contract", "name": "Date contract" },
            { "field": "Date Shift Contract", "name": "Date shift contract" },
            { "field": "Time Contract", "name": "Time contract" }
          ]
        }
