{
  "name": "formula-summary",
  "outputName": "formula-summary.xlsx",
  "sheets": [
    {
      "name": "Inputs",
      "ranges": [
        {
          "range": "A1:C4",
          "values": [
            ["Month", "Revenue", "Cost"],
            ["Jan", 100, 60],
            ["Feb", 120, 70],
            ["Mar", 150, 90]
          ]
        },
        {
          "range": "A1:C1",
          "format": {
            "fill": "#0F766E",
            "font": { "bold": true, "color": "#FFFFFF" },
            "alignment": { "horizontal": "center" }
          }
        },
        {
          "range": "B2:C4",
          "format": { "numberFormat": "$#,##0" }
        }
      ],
      "tables": [
        { "range": "A1:C4", "name": "InputsTable", "style": "TableStyleMedium4" }
      ]
    },
    {
      "name": "Summary",
      "ranges": [
        {
          "range": "A1:D4",
          "values": [
            ["Month", "Revenue", "Cost", "Margin"],
            ["Jan", null, null, null],
            ["Feb", null, null, null],
            ["Mar", null, null, null]
          ]
        },
        {
          "range": "B2:D4",
          "formulas": [
            ["=Inputs!B2", "=Inputs!C2", "=(B2-C2)/B2"],
            ["=Inputs!B3", "=Inputs!C3", "=(B3-C3)/B3"],
            ["=Inputs!B4", "=Inputs!C4", "=(B4-C4)/B4"]
          ]
        },
        {
          "range": "A1:D1",
          "format": {
            "fill": "#0F172A",
            "font": { "bold": true, "color": "#FFFFFF" },
            "alignment": { "horizontal": "center" },
            "border": { "style": "thin", "color": "#334155" }
          }
        },
        {
          "range": "B2:C4",
          "format": { "numberFormat": "$#,##0" }
        },
        {
          "range": "D2:D4",
          "format": { "numberFormat": "0.0%" }
        },
        {
          "range": "F1:G9",
          "values": [
            ["Statistic", "Value"],
            ["Median revenue", null],
            ["Second largest", null],
            ["Smallest", null],
            ["March rank", null],
            ["Rounded median", null],
            ["Margin round up", null],
            ["Margin round down", null],
            ["Mode margin", null]
          ]
        },
        {
          "range": "G2:G9",
          "formulas": [
            ["=MEDIAN(B2:B4)"],
            ["=LARGE(B2:B4,2)"],
            ["=SMALL(B2:B4,1)"],
            ["=RANK.EQ(B4,B2:B4)"],
            ["=ROUND(G2,-2)"],
            ["=ROUNDUP(D3,2)"],
            ["=ROUNDDOWN(D3,2)"],
            ["=MODE.SNGL(D2:D4)"]
          ]
        },
        {
          "range": "F1:G1",
          "format": {
            "fill": "#7C3AED",
            "font": { "bold": true, "color": "#FFFFFF" }
          }
        }
      ],
      "tables": [
        { "range": "A1:D4", "name": "SummaryTable", "style": "TableStyleMedium2" }
      ]
    }
  ],
  "expectations": [
    {
      "sheet": "Summary",
      "range": "B2:D4",
      "values": [
        [100, 60, 0.4],
        [120, 70, 0.4166666666666667],
        [150, 90, 0.4]
      ]
    },
    {
      "sheet": "Summary",
      "range": "G2:G9",
      "values": [[120], [120], [100], [1], [100], [0.42], [0.41], [0.4]]
    }
  ],
  "qa": {
    "sheetName": "Summary",
    "range": "A1:G9",
    "renderFormat": "svg",
    "inspectKind": "workbook,sheet,table,formula,style,computedStyle",
    "maxChars": 12000
  }
}
