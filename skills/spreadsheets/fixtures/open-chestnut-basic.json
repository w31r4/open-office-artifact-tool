{
  "name": "open-chestnut-basic",
  "outputName": "open-chestnut-basic.xlsx",
  "codec": "open-chestnut",
  "roundtripCodec": "open-chestnut",
  "dateSystem": "1904",
  "theme": {
    "name": "OpenChestnut Fixture",
    "colors": {
      "dk1": "#101820", "lt1": "#F8FAFC", "dk2": "#1E3A5F", "lt2": "#E2E8F0",
      "accent1": "#0F766E", "accent2": "#C2410C", "accent3": "#4D7C0F", "accent4": "#7E22CE",
      "accent5": "#0369A1", "accent6": "#BE123C", "hlink": "#1D4ED8", "folHlink": "#7E22CE"
    }
  },
  "definedNames": [
    { "id": "defined-name/summary-values", "name": "SummaryValues", "refersTo": "Summary!$B$2:$B$3", "comment": "Fixture summary values", "hidden": false },
    { "id": "defined-name/detail-scores", "name": "DetailScores", "refersTo": "Details!$C$2:$C$3", "scope": "Details", "hidden": true }
  ],
  "sheets": [
    {
      "name": "Summary",
      "showGridLines": false,
      "freezePanes": { "rows": 1, "columns": 1 },
      "sortState": {
        "reference": "A1:D3",
        "caseSensitive": true,
        "sortMethod": "stroke",
        "columnSort": true,
        "conditions": [
          { "reference": "A3:D3", "descending": true, "customList": "Double,Revenue" },
          { "reference": "A1:D1", "descending": false }
        ]
      },
      "ranges": [
        {
          "range": "A1:B3",
          "values": [
            ["Metric", "Value"],
            ["Revenue", 42.5],
            ["Double", null]
          ]
        },
        {
          "range": "B3",
          "formulas": [["=B2*2"]]
        },
        {
          "range": "C1:D1",
          "values": [["Shared", "Array"]]
        },
        {
          "range": "C2:C3",
          "formulas": [["=B2*2"], ["=B3*2"]],
          "formulaMetadata": { "kind": "shared", "sharedIndex": 7, "reference": "C2:C3" }
        },
        {
          "range": "D2",
          "formulas": [["=SUM(B2:B3)"]],
          "formulaMetadata": { "kind": "array", "reference": "D2:D3" }
        },
        {
          "range": "A1:D1",
          "format": {
            "fill": { "patternType": "darkGrid", "foreground": { "theme": 4, "tint": 0.4 }, "background": "#E2E8F0" },
            "font": { "bold": true, "underline": "double", "color": "#FFFFFF", "size": 12, "name": "Aptos Display" },
            "alignment": { "horizontal": "center", "vertical": "bottom", "wrapText": true, "textRotation": 15, "indent": 1, "readingOrder": 1 },
            "border": {
              "left": { "style": "thin", "color": { "indexed": 8 } },
              "right": { "style": "thin", "color": { "indexed": 8 } },
              "top": { "style": "thin", "color": { "auto": true } },
              "bottom": { "style": "double", "color": "#38BDF8" }
            },
            "protection": { "locked": false, "hidden": true }
          }
        },
        {
          "range": "C2:C3",
          "format": { "fill": "#DCFCE7", "font": { "bold": true, "color": "#166534" }, "alignment": { "horizontal": "right" } }
        },
        {
          "range": "B2",
          "format": { "numberFormat": "0.000 \"units\"" }
        },
        {
          "range": "B3",
          "format": { "numberFormat": "0.00%" }
        },
        {
          "range": "A4:B4",
          "values": [["Ready", true]],
          "merge": true
        }
      ]
    },
    {
      "name": "Details",
      "ranges": [
        {
          "range": "A1:C4",
          "values": [
            ["Codec", "Runtime", "Score"],
            ["OpenChestnut", "WebAssembly", 10],
            ["JS fallback", "Node", 5],
            ["Total", "", 23]
          ]
        },
        {
          "range": "C2:C3",
          "formulas": [["=LEN(A2)"], ["=LEN(A3)"]]
        },
        {
          "range": "C4",
          "formulas": [["=SUM(C2:C3)"]]
        }
      ],
      "tables": [
        {
          "range": "A1:C4",
          "name": "CodecTable",
          "style": "TableStyleMedium4",
          "showTotals": true,
          "showFirstColumn": true,
          "showRowStripes": false,
          "showBandedColumns": true,
          "filters": [
            { "columnIndex": 0, "kind": "values", "values": ["OpenChestnut"], "includeBlank": false },
            {
              "columnIndex": 2,
              "kind": "custom",
              "matchAll": true,
              "criteria": [
                { "operator": "greaterThanOrEqual", "value": "5" },
                { "operator": "lessThanOrEqual", "value": "20" }
              ]
            }
          ],
          "sortState": {
            "reference": "A2:C3",
            "caseSensitive": true,
            "sortMethod": "stroke",
            "conditions": [
              { "reference": "C2:C3", "descending": true, "customList": "20,10" },
              { "reference": "A2:A3", "descending": false }
            ]
          },
          "columnDefinitions": [
            { "name": "Codec", "totalsRowFunction": "none", "totalsRowLabel": "Total" },
            { "name": "Runtime" },
            { "name": "Score", "calculatedColumnFormula": "=LEN([@Codec])", "totalsRowFunction": "custom", "totalsRowFormula": "=SUBTOTAL(109,[Score])" }
          ]
        }
      ]
    },
    {
      "name": "Advanced Filters",
      "ranges": [
        {
          "range": "A1:C3",
          "values": [
            ["Date", "Status", "Score"],
            [45853, "ready", 95],
            [45854, "pending", 80]
          ]
        },
        {
          "range": "A2:A3",
          "format": { "numberFormat": "yyyy-mm-dd" }
        }
      ],
      "tables": [
        {
          "range": "A1:C3",
          "name": "AdvancedFilterTable",
          "style": "TableStyleMedium6",
          "filters": [
            {
              "columnIndex": 0,
              "kind": "values",
              "values": [],
              "includeBlank": false,
              "calendarType": "gregorian",
              "dateGroups": [{ "grouping": "day", "year": 2026, "month": 7, "day": 15 }]
            },
            { "columnIndex": 1, "kind": "dynamic", "type": "today", "value": 45853, "maxValue": 45854 },
            { "columnIndex": 2, "kind": "top10", "top": true, "percent": true, "value": 10, "filterValue": 95 }
          ]
        }
      ]
    },
    {
      "name": "Icon Rules",
      "ranges": [
        {
          "range": "A1:B3",
          "values": [
            ["Trend", "Rating"],
            [1, 5],
            [2, 3]
          ]
        }
      ],
      "tables": [
        {
          "range": "A1:B3",
          "name": "IconRuleTable",
          "style": "TableStyleMedium7",
          "filters": [
            { "columnIndex": 0, "kind": "icon", "iconSet": "3Arrows", "iconId": 0 },
            { "columnIndex": 1, "kind": "icon", "iconSet": "3Flags" }
          ],
          "sortState": {
            "reference": "A2:B3",
            "caseSensitive": false,
            "conditions": [
              { "reference": "B2:B3", "descending": true, "kind": "icon", "iconSet": "5Rating", "iconId": 4 },
              { "reference": "A2:A3", "descending": false, "kind": "icon", "iconSet": "3Symbols2" }
            ]
          }
        }
      ]
    },
    {
      "name": "Color Rules",
      "ranges": [
        {
          "range": "A1:B3",
          "values": [
            ["Fill", "Font"],
            [1, 5],
            [2, 3]
          ]
        }
      ],
      "tables": [
        {
          "range": "A1:B3",
          "name": "ColorRuleTable",
          "style": "TableStyleMedium8",
          "filters": [
            { "columnIndex": 0, "kind": "color", "target": "cell", "color": "#E11D48" },
            { "columnIndex": 1, "kind": "color", "target": "font", "color": { "theme": 4, "tint": -0.25 } }
          ],
          "sortState": {
            "reference": "A2:B3",
            "caseSensitive": false,
            "conditions": [
              { "reference": "B2:B3", "descending": true, "kind": "color", "target": "font", "color": { "theme": 4, "tint": -0.25 } },
              { "reference": "A2:A3", "descending": false, "kind": "color", "target": "cell", "color": "#E11D48" }
            ]
          }
        }
      ]
    }
  ],
  "expectations": [
    { "sheet": "Summary", "range": "B2:D3", "values": [[42.5, 85, 127.5], [85, 170, null]] }
  ],
  "qa": {
    "sheetName": "Summary",
    "range": "A1:D4",
    "renderFormat": "png",
    "inspectKind": "workbook,sheet,formula,merge,dimension",
    "maxChars": 16000,
    "nativeRender": "auto"
  }
}
