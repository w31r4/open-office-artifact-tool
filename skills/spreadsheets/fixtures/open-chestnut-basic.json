{
  "name": "open-chestnut-basic",
  "outputName": "open-chestnut-basic.xlsx",
  "dateSystem": "1904",
  "roundtripEdits": {
    "charts": [
      { "sheet": "Dashboard", "name": "Line chart", "title": "Edited line trend" }
    ],
    "images": [
      { "sheet": "Dashboard", "name": "OpenChestnut mark", "alt": "Edited OpenChestnut marker" }
    ]
  },
  "sheets": [
    {
      "name": "Dashboard",
      "freezePanes": { "rows": 1 },
      "ranges": [
        {
          "range": "A1:D4",
          "values": [
            ["Label", "Actual", "Double", "State"],
            ["A", 10, null, "Ready"],
            ["B", 20, null, "Review"],
            ["C", 30, null, "Ready"]
          ]
        },
        { "range": "C2:C4", "formulas": [["=B2*2"], ["=B3*2"], ["=B4*2"]] },
        {
          "range": "A1:D1",
          "format": {
            "fill": "#0F766E",
            "font": { "bold": true, "color": "#FFFFFF" },
            "border": { "bottom": { "style": "double", "color": "#38BDF8" } },
            "alignment": { "horizontal": "center" }
          }
        },
        { "range": "B2:C4", "format": { "numberFormat": "0.00", "columnWidthPx": 84 } },
        {
          "range": "D2:D4",
          "dataValidation": { "rule": { "type": "list", "values": ["Ready", "Review"] } },
          "conditionalFormats": [
            { "ruleType": "containsText", "config": { "text": "Review", "formula": "NOT(ISERROR(SEARCH(\"Review\",D2)))", "format": { "fill": "#FEF3C7" } } }
          ]
        },
        {
          "range": "B2:B4",
          "conditionalFormats": [
            { "ruleType": "colorScale", "config": { "colors": ["#FEE2E2", "#22C55E"] } }
          ]
        },
        { "range": "A6:D6", "values": [["Canonical roundtrip", null, null, null]], "merge": true, "format": { "fill": "#E2E8F0", "font": { "bold": true } } }
      ],
      "tables": [
        { "range": "A1:D4", "name": "CodecTable", "style": "TableStyleMedium4", "showRowStripes": true }
      ],
      "charts": [
        { "chartType": "bar", "name": "Bar chart", "title": "Actual values", "sourceRange": "A1:B4", "topLeft": "F1", "bottomRight": "J10" },
        { "chartType": "line", "name": "Line chart", "title": "Double trend", "sourceRange": "A1:C4", "topLeft": "K1", "bottomRight": "O10" },
        { "chartType": "pie", "name": "Pie chart", "title": "Actual share", "sourceRange": "A1:B4", "topLeft": "F12", "bottomRight": "J22" }
      ],
      "images": [
        {
          "name": "OpenChestnut mark",
          "alt": "OpenChestnut worksheet marker",
          "dataUrl": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAIAAAACCAQAAABFaP0WAAAADUlEQVR42mNk+M/wHwAF/gL+3c5GAAAAAElFTkSuQmCC",
          "anchor": { "from": { "row": 7, "col": 0, "rowOffsetPx": 4, "colOffsetPx": 4 }, "extent": { "widthPx": 72, "heightPx": 48 } }
        }
      ]
    }
  ],
  "definedNames": [
    { "name": "ActualValues", "refersTo": "Dashboard!$B$2:$B$4", "comment": "Canonical numeric input" }
  ],
  "activeWorksheet": "Dashboard",
  "expectations": [
    { "sheet": "Dashboard", "range": "C2:C4", "values": [[20], [40], [60]] }
  ],
  "qa": {
    "sheetName": "Dashboard",
    "range": "A1:O22",
    "renderFormat": "png",
    "inspectKind": "workbook,sheet,table,formula,style,computedStyle,drawing",
    "maxChars": 16000
  }
}
