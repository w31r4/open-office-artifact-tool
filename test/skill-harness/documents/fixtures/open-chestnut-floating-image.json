{
  "name": "open-chestnut-floating-image",
  "outputName": "floating-image-review.docx",
  "defaultRunStyle": {
    "fontFamily": "Aptos",
    "fontSize": 22,
    "color": "#172033"
  },
  "blocks": [
    {
      "kind": "paragraph",
      "name": "title",
      "styleId": "Title",
      "text": "Floating Figure"
    },
    {
      "kind": "image",
      "name": "architecture-figure",
      "styleId": "Normal",
      "alt": "Blue and green architecture figure",
      "widthPx": 240,
      "heightPx": 120,
      "dataUrl": "data:image/png;base64,",
      "placement": {
        "type": "floating",
        "horizontal": { "relativeTo": "margin", "offsetPx": 260 },
        "vertical": { "relativeTo": "paragraph", "offsetPx": 0 },
        "wrap": "square",
        "wrapSide": "bothSides",
        "distanceFromTextPx": { "top": 4, "right": 12, "bottom": 4, "left": 12 }
      }
    },
    {
      "kind": "paragraph",
      "name": "caption",
      "text": "Figure 1. Bounded OpenChestnut floating-image placement."
    },
    {
      "kind": "paragraph",
      "name": "lead",
      "text": "Inspect the anchored figure before delivery."
    },
    {
      "kind": "paragraph",
      "name": "review-one",
      "text": "The native render must keep this figure inside the page margins."
    },
    {
      "kind": "paragraph",
      "name": "review-two",
      "text": "OpenChestnut must preserve the image while changing only its anchor."
    }
  ],
  "edits": [
    {
      "kind": "image",
      "matchAlt": "Blue and green architecture figure",
      "placement": {
        "type": "floating",
        "horizontal": { "relativeTo": "page", "offsetPx": 150 },
        "vertical": { "relativeTo": "paragraph", "offsetPx": 0 },
        "wrap": "topAndBottom",
        "distanceFromTextPx": { "top": 8, "right": 0, "bottom": 8, "left": 0 }
      }
    }
  ],
  "expectInspect": [
    { "kind": "image", "pattern": "Blue and green architecture figure" },
    { "kind": "image", "pattern": "floating" },
    { "kind": "paragraph", "pattern": "Figure 1" }
  ],
  "qa": {
    "previewFormat": "png",
    "nativeRender": "auto",
    "inspectKind": "document,paragraph,image,layout",
    "maxChars": 16000
  }
}
