{
  "name": "business-brief",
  "outputName": "business-brief.docx",
  "defaultRunStyle": {
    "fontFamily": "Aptos",
    "fontSize": 22,
    "color": "#202020"
  },
  "styles": {
    "BriefLead": {
      "name": "Brief Lead",
      "type": "paragraph",
      "basedOn": "Normal",
      "fontFamily": "Aptos Display",
      "fontSize": 30,
      "bold": true,
      "alignment": "center",
      "spaceAfterTwips": 240,
      "keepNext": true
    }
  },
  "settings": {
    "evenAndOddHeaders": true
  },
  "sectionSettings": [
    { "sectionIndex": 0, "differentFirstPage": true }
  ],
  "headers": [
    { "name": "default-header", "text": "Clean-room document workflow", "referenceType": "default", "sectionIndex": 0, "variantActive": true },
    { "name": "first-header", "text": "Office artifact readiness brief", "referenceType": "first", "sectionIndex": 0, "variantActive": true }
  ],
  "footers": [
    { "name": "even-footer", "text": "1", "fieldInstruction": "PAGE", "referenceType": "even", "sectionIndex": 0, "variantActive": true }
  ],
  "blocks": [
    { "kind": "paragraph", "name": "title", "styleId": "Title", "text": "Office artifact readiness brief" },
    { "kind": "paragraph", "name": "comment-target", "styleId": "Normal", "text": "Review the delivery evidence before release." },
    {
      "kind": "paragraph",
      "name": "editable-lead",
      "styleId": "BriefLead",
      "text": "Create, inspect, render, and verify a real DOCX.",
      "paragraphFormat": { "alignment": "center", "leftIndentTwips": 360, "spaceAfterTwips": 240, "lineSpacingTwips": 300, "lineSpacingRule": "auto", "keepNext": true },
      "runs": [
        { "text": "Create, inspect, render, and verify a real DOCX.", "style": { "fontFamily": "Aptos Display", "fontSize": 30, "color": "#315A83", "characterSpacingTwips": 10, "bold": true, "italic": false, "underline": true } }
      ]
    },
    { "kind": "listItem", "name": "semantic-step", "styleId": "Normal", "listType": "bullet", "numberFormat": "bullet", "levelText": "•", "numberingId": 71, "abstractNumberingId": 7, "text": "Inspect stable document blocks." },
    { "kind": "listItem", "name": "render-step", "styleId": "Normal", "listType": "number", "numberFormat": "decimal", "start": 1, "levelText": "%1.", "numberingId": 72, "abstractNumberingId": 8, "text": "Render through LibreOffice and Poppler." },
    {
      "kind": "table",
      "name": "readiness-table",
      "styleId": "TableGrid",
      "widthDxa": 9000,
      "columnWidthsDxa": [3000, 3000, 3000],
      "headerFill": "E2E8F0",
      "values": [
        ["Gate", "Evidence", "Status"],
        ["Semantic", "inspect + verify", "Pending"],
        ["Visual", "page PNG", "Required"]
      ]
    },
    { "kind": "hyperlink", "name": "standards-link", "styleId": "Normal", "text": "OOXML overview", "url": "https://learn.microsoft.com/office/open-xml/open-xml-sdk", "tooltip": "Open the Open XML SDK documentation", "history": true },
    { "kind": "image", "name": "status-mark", "styleId": "Normal", "alt": "Green status mark", "widthPx": 40, "heightPx": 40, "dataUrl": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO+/p9sAAAAASUVORK5CYII=" },
    { "kind": "field", "name": "page-number", "styleId": "Normal", "instruction": "PAGE", "display": "1" },
    { "kind": "section", "name": "evidence-section", "breakType": "continuous", "orientation": "landscape", "pageSize": { "widthTwips": 15840, "heightTwips": 12240 }, "margins": { "top": 720, "right": 900, "bottom": 720, "left": 900 } },
    { "kind": "paragraph", "name": "second-section", "styleId": "Normal", "text": "Second-section evidence remains editable." }
  ],
  "comments": [
    { "name": "delivery-review", "targetName": "comment-target", "author": "QA Agent", "initials": "QA", "date": "2026-07-16T08:00:00Z", "text": "Confirm the delivery evidence." }
  ],
  "edits": [
    { "kind": "paragraph", "matchText": "Create, inspect, render, and verify a real DOCX.", "text": "Create, inspect, render, and verify the canonical DOCX path.", "paragraphFormat": { "alignment": "left" }, "runStyle": { "color": "#9C2B2E" } },
    { "kind": "listItem", "matchText": "Inspect stable document blocks.", "text": "Inspect stable document blocks and fields." },
    { "kind": "tableCell", "matchText": "Pending", "row": 1, "column": 2, "value": "Pass" },
    { "kind": "hyperlink", "matchText": "OOXML overview", "url": "https://learn.microsoft.com/office/open-xml/word-processing", "tooltip": "Edited through the canonical Office path", "history": false },
    { "kind": "image", "matchAlt": "Green status mark", "alt": "Edited green status mark", "widthPx": 48 },
    { "kind": "field", "matchInstruction": "PAGE", "instruction": "NUMPAGES", "display": "2" },
    { "kind": "section", "index": 0, "margins": { "left": 1200 } },
    { "kind": "comment", "matchText": "Confirm the delivery evidence.", "author": "Lead reviewer", "initials": "LR", "text": "Delivery evidence approved." }
  ],
  "expectInspect": [
    { "kind": "paragraph", "pattern": "Office artifact readiness brief" },
    { "kind": "listItem", "pattern": "Inspect stable document blocks" },
    { "kind": "table", "pattern": "readiness-table" },
    { "kind": "comment", "pattern": "Confirm the delivery evidence" },
    { "kind": "header", "pattern": "Clean-room document workflow" },
    { "kind": "image", "pattern": "Green status mark" }
  ],
  "qa": {
    "previewFormat": "svg",
    "nativeRender": "auto",
    "inspectKind": "document,paragraph,listItem,table,comment,header,footer,hyperlink,field,image,section,style,layout",
    "maxChars": 24000
  }
}
