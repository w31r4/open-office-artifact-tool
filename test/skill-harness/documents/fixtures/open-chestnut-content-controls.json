{
  "name": "open-chestnut-content-controls",
  "outputName": "open-chestnut-content-controls.docx",
  "blocks": [
    {
      "kind": "paragraph",
      "styleId": "Title",
      "text": "Agent-fillable customer template"
    },
    {
      "kind": "paragraph",
      "name": "customer-fields",
      "styleId": "Normal",
      "runs": [
        { "text": "Customer: " },
        { "text": "{{CUSTOMER_NAME}}", "contentControl": { "id": "customer-name", "tag": "CUSTOMER_NAME", "alias": "Customer name" } },
        { "text": " / Account: " },
        { "text": "{{ACCOUNT_ID}}", "contentControl": { "id": "account-id", "tag": "ACCOUNT_ID", "alias": "Account ID" } },
        { "text": " / Priority: " },
        { "text": "", "contentControl": { "id": "priority", "tag": "PRIORITY", "alias": "Priority", "controlType": "dropdown", "selectedValue": "medium", "choices": [{ "displayText": "Low", "value": "low" }, { "displayText": "Medium", "value": "medium" }, { "displayText": "High", "value": "high" }] } },
        { "text": " / Contact: " },
        { "text": "", "contentControl": { "id": "contact-method", "tag": "CONTACT_METHOD", "alias": "Contact method", "controlType": "comboBox", "value": "email", "choices": [{ "displayText": "Email", "value": "email" }, { "displayText": "Phone call", "value": "phone" }] } },
        { "text": " / Review date: " },
        { "text": "", "contentControl": { "id": "review-date", "tag": "REVIEW_DATE", "alias": "Review date", "controlType": "date", "dateValue": "2026-07-21" } },
        { "text": " / Approved: " },
        { "text": "", "contentControl": { "id": "approved", "tag": "APPROVED", "alias": "Approved", "controlType": "checkbox", "checked": false } }
      ]
    },
    {
      "kind": "paragraph",
      "name": "executive-summary-field",
      "styleId": "Normal",
      "blockContentControl": { "id": "executive-summary", "tag": "EXECUTIVE_SUMMARY", "alias": "Executive summary", "controlType": "text" },
      "runs": [
        { "text": "{{EXECUTIVE_SUMMARY}}", "style": { "bold": true, "color": "#1D4ED8" } }
      ]
    },
    {
      "kind": "table",
      "name": "approval-matrix",
      "styleId": "TableGrid",
      "values": [
        ["Approval field", "Value"],
        ["Owner", "{{TABLE_OWNER}}"],
        ["Approved", "pending"],
        ["Priority", "pending"],
        ["Contact", "pending"],
        ["Review date", "pending"]
      ],
      "cellContentControls": [
        {
          "row": 1,
          "column": 1,
          "control": { "id": "table-owner", "tag": "TABLE_OWNER", "alias": "Table owner", "controlType": "text" }
        },
        {
          "row": 2,
          "column": 1,
          "control": { "id": "table-approved", "tag": "TABLE_APPROVED", "alias": "Table approved", "controlType": "checkbox", "checked": false }
        },
        {
          "row": 3,
          "column": 1,
          "control": { "id": "table-priority", "tag": "TABLE_PRIORITY", "alias": "Table priority", "controlType": "dropdown", "selectedValue": "low", "choices": [{ "displayText": "Low", "value": "low" }, { "displayText": "High", "value": "high" }] }
        },
        {
          "row": 4,
          "column": 1,
          "control": { "id": "table-contact", "tag": "TABLE_CONTACT", "alias": "Table contact", "controlType": "comboBox", "value": "Email", "choices": [{ "displayText": "Email", "value": "email" }, { "displayText": "Phone call", "value": "phone" }] }
        },
        {
          "row": 5,
          "column": 1,
          "control": { "id": "table-review-date", "tag": "TABLE_REVIEW_DATE", "alias": "Table review date", "controlType": "date", "dateValue": "2026-07-21" }
        }
      ]
    }
  ],
  "edits": [
    {
      "kind": "contentControls",
      "values": {
        "CUSTOMER_NAME": "Grace Hopper",
        "ACCOUNT_ID": "AC-2048",
        "EXECUTIVE_SUMMARY": "Ready for approval",
        "TABLE_OWNER": "Katherine Johnson"
      },
      "expectUpdated": 4
    },
    {
      "kind": "checkboxContentControls",
      "values": {
        "APPROVED": true,
        "TABLE_APPROVED": true
      },
      "expectUpdated": 2
    },
    {
      "kind": "dropdownContentControls",
      "values": {
        "PRIORITY": "high",
        "TABLE_PRIORITY": "high"
      },
      "expectUpdated": 2
    },
    {
      "kind": "comboBoxContentControls",
      "values": {
        "CONTACT_METHOD": "Pager duty",
        "TABLE_CONTACT": "In person"
      },
      "expectUpdated": 2
    },
    {
      "kind": "dateContentControls",
      "values": {
        "REVIEW_DATE": "2028-02-29",
        "TABLE_REVIEW_DATE": "2028-02-29"
      },
      "expectUpdated": 2
    }
  ],
  "expectInspect": [
    { "kind": "contentControl", "pattern": "CUSTOMER_NAME" },
    { "kind": "contentControl", "pattern": "ACCOUNT_ID" },
    { "kind": "contentControl", "pattern": "APPROVED" },
    { "kind": "contentControl", "pattern": "checkbox" },
    { "kind": "contentControl", "pattern": "PRIORITY" },
    { "kind": "contentControl", "pattern": "dropdown" },
    { "kind": "contentControl", "pattern": "CONTACT_METHOD" },
    { "kind": "contentControl", "pattern": "comboBox" },
    { "kind": "contentControl", "pattern": "REVIEW_DATE" },
    { "kind": "contentControl", "pattern": "dateValue" },
    { "kind": "contentControl", "pattern": "EXECUTIVE_SUMMARY" },
    { "kind": "contentControl", "pattern": "block" },
    { "kind": "contentControl", "pattern": "TABLE_OWNER" },
    { "kind": "contentControl", "pattern": "tableCell" },
    { "kind": "contentControl", "pattern": "TABLE_APPROVED" },
    { "kind": "contentControl", "pattern": "TABLE_PRIORITY" },
    { "kind": "contentControl", "pattern": "TABLE_CONTACT" },
    { "kind": "contentControl", "pattern": "TABLE_REVIEW_DATE" }
  ],
  "qa": {
    "previewFormat": "svg",
    "nativeRender": "auto",
    "inspectKind": "document,paragraph,contentControl,layout",
    "maxChars": 12000
  }
}
