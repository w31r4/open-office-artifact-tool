{
  "name": "package-settings",
  "outputName": "package-settings.docx",
  "settings": { "evenAndOddHeaders": true, "mirrorMargins": true, "gutterAtTop": true },
  "sectionSettings": [
    { "sectionIndex": 0, "differentFirstPage": true }
  ],
  "headers": [
    { "name": "first-page", "text": "First-page review", "referenceType": "first", "sectionIndex": 0, "variantActive": true },
    { "name": "even-page", "text": "Even-page review", "referenceType": "even", "sectionIndex": 0, "variantActive": true }
  ],
  "footers": [
    { "name": "page-number", "text": "1", "fieldInstruction": "PAGE", "referenceType": "default", "sectionIndex": 0, "variantActive": true }
  ],
  "blocks": [
    { "kind": "paragraph", "name": "title", "styleId": "Title", "text": "Section and header settings" },
    { "kind": "field", "name": "page-count", "styleId": "Normal", "instruction": "NUMPAGES", "display": "1" },
    { "kind": "paragraph", "name": "review-note", "styleId": "Normal", "text": "Review first-page and even-page variants." },
    { "kind": "section", "name": "binding-layout", "breakType": "continuous", "pageSize": { "widthTwips": 12240, "heightTwips": 15840 }, "margins": { "top": 1440, "right": 1440, "bottom": 1440, "left": 1440, "gutter": 720 }, "columns": { "count": 2, "spacing": 720, "separator": true } }
  ],
  "expectInspect": [
    { "kind": "field", "pattern": "NUMPAGES" },
    { "kind": "header", "pattern": "First-page review" },
    { "kind": "footer", "pattern": "PAGE" },
    { "kind": "section", "pattern": "\"gutter\":720" },
    { "kind": "section", "pattern": "\"columns\":{\"count\":2,\"spacing\":720,\"separator\":true}" }
  ],
  "qa": {
    "previewFormat": "svg",
    "nativeRender": "auto",
    "inspectKind": "document,settings,section,paragraph,header,footer,field,style,layout",
    "maxChars": 12000
  }
}
