{
  "name": "open-chestnut-toc",
  "outputName": "open-chestnut-toc.docx",
  "blocks": [
    { "kind": "paragraph", "styleId": "Title", "text": "Native table of contents" },
    {
      "kind": "toc",
      "id": "field/toc",
      "styleId": "Normal",
      "levels": "1-3",
      "display": "Refresh fields before delivery"
    },
    { "kind": "paragraph", "styleId": "Heading1", "text": "Executive summary" },
    { "kind": "paragraph", "styleId": "Heading2", "text": "Decision" },
    { "kind": "paragraph", "styleId": "Heading1", "text": "Evidence" }
  ],
  "edits": [
    {
      "kind": "field",
      "matchInstruction": "TOC \\o \"1-3\" \\h \\z \\u",
      "instruction": "TOC \\o \"1-4\" \\h \\z \\u",
      "display": "Update this table of contents in Word"
    }
  ],
  "expectInspect": [
    { "kind": "field", "pattern": "TOC" },
    { "kind": "settings", "pattern": "updateFields" }
  ],
  "qa": {
    "previewFormat": "svg",
    "nativeRender": "auto",
    "inspectKind": "document,paragraph,field,settings,layout",
    "maxChars": 12000
  }
}
