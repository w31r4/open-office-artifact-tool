{
  "name": "package-comments",
  "outputName": "package-comments.docx",
  "blocks": [
    { "kind": "paragraph", "name": "title", "styleId": "Title", "text": "Classic comment review" },
    { "kind": "paragraph", "name": "decision", "styleId": "Normal", "text": "Approve after document review." },
    { "kind": "table", "name": "evidence-table", "styleId": "TableGrid", "values": [["Gate", "Status"], ["Document", "Pass"]] }
  ],
  "comments": [
    { "name": "decision-comment", "targetName": "decision", "author": "QA Agent", "initials": "QA", "date": "2026-07-12T09:30:00Z", "text": "Confirm the decision paragraph." }
  ],
  "edits": [
    { "kind": "comment", "matchText": "Confirm the decision paragraph.", "author": "QA Lead", "initials": "QL", "text": "Decision paragraph confirmed." }
  ],
  "expectInspect": [
    { "kind": "paragraph", "pattern": "Approve after document review" },
    { "kind": "table", "pattern": "evidence-table" },
    { "kind": "comment", "pattern": "Confirm the decision paragraph" }
  ],
  "qa": {
    "previewFormat": "svg",
    "nativeRender": "auto",
    "inspectKind": "document,paragraph,table,comment,style,layout",
    "maxChars": 12000
  }
}
