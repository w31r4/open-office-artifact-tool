{
  "name": "formula-summary",
  "outputName": "formula-summary.xlsx",
  "dateSystem": "1900",
  "theme": {
    "name": "Canonical Spreadsheet Theme",
    "colors": { "accent1": "#0F766E", "accent2": "#7C3AED", "accent3": "#38BDF8" }
  },
  "sheets": [
    {
      "name": "Summary",
      "showGridLines": false,
      "freezePanes": { "rows": 1, "columns": 1 },
      "ranges": [
        {
          "range": "A1:D4",
          "values": [
            ["Month", "Revenue", "Cost", "Status"],
            ["Jan", 100, 60, "Done"],
            ["Feb", 120, 70, "In progress"],
            ["Mar", 150, 90, "Planned"]
          ]
        },
        {
          "range": "E1:E4",
          "values": [["Margin"], [null], [null], [null]],
          "formulas": [[null], ["=(B2-C2)/B2"], ["=(B3-C3)/B3"], ["=(B4-C4)/B4"]]
        },
        {
          "range": "A1:E1",
          "format": {
            "fill": "#0F766E",
            "font": { "bold": true, "color": "#FFFFFF" },
            "alignment": { "horizontal": "center" },
            "rowHeightPx": 28
          }
        },
        { "range": "B2:C4", "format": { "numberFormat": "$#,##0", "columnWidthPx": 88 } },
        {
          "range": "D2:D4",
          "dataValidation": { "rule": { "type": "list", "values": ["Planned", "In progress", "Done"] } }
        },
        {
          "range": "E2:E4",
          "format": { "numberFormat": "0.0%" },
          "conditionalFormats": [
            { "ruleType": "cellIs", "config": { "operator": "greaterThan", "formula": "0.4", "format": { "fill": "#DCFCE7" } } },
            { "ruleType": "colorScale", "config": { "colors": ["#FEE2E2", "#FEF3C7", "#22C55E"] } }
          ]
        },
        { "range": "A6:E6", "values": [["Quarter summary", null, null, null, null]], "merge": true, "format": { "fill": "#0F766E", "font": { "bold": true, "color": "#FFFFFF" } } }
      ],
      "tables": [
        { "range": "A1:E4", "name": "SummaryTable", "style": "TableStyleMedium4", "showRowStripes": true }
      ],
      "charts": [
        { "chartType": "line", "name": "Revenue trend", "title": "Revenue by month", "sourceRange": "A1:B4", "hasLegend": false, "topLeft": "G1", "bottomRight": "L12" }
      ],
      "images": [
        {
          "name": "Status mark",
          "alt": "Green status marker",
          "dataUrl": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAIAAAACCAQAAABFaP0WAAAADUlEQVR42mNk+M/wHwAF/gL+3c5GAAAAAElFTkSuQmCC",
          "anchor": { "from": { "row": 7, "col": 0 }, "extent": { "widthPx": 48, "heightPx": 48 } }
        }
      ]
    }
  ],
  "commentSelf": { "displayName": "Spreadsheet Agent" },
  "comments": [
    {
      "id": "margin-review",
      "sheet": "Summary",
      "address": "E2",
      "text": "Check the modeled margin.",
      "author": "Reviewer",
      "resolved": true,
      "comment": {
        "id": "{11111111-1111-4111-8111-111111111111}",
        "personId": "{AAAAAAAA-AAAA-4AAA-8AAA-AAAAAAAAAAAA}",
        "date": "2026-07-16T09:00:00.000Z",
        "person": {
          "id": "{AAAAAAAA-AAAA-4AAA-8AAA-AAAAAAAAAAAA}",
          "displayName": "Reviewer",
          "userId": "reviewer@example.com",
          "providerId": "None"
        }
      },
      "replies": [
        {
          "text": "Confirmed against the modeled source data.",
          "id": "{22222222-2222-4222-8222-222222222222}",
          "personId": "{BBBBBBBB-BBBB-4BBB-8BBB-BBBBBBBBBBBB}",
          "author": "Lead reviewer",
          "date": "2026-07-16T09:30:00.000Z",
          "person": {
            "id": "{BBBBBBBB-BBBB-4BBB-8BBB-BBBBBBBBBBBB}",
            "displayName": "Lead reviewer",
            "userId": "lead@example.com",
            "providerId": "None"
          }
        }
      ]
    }
  ],
  "activeWorksheet": "Summary",
  "expectations": [
    { "sheet": "Summary", "range": "E2:E4", "values": [[0.4], [0.4166666666666667], [0.4]] }
  ],
  "qa": {
    "sheetName": "Summary",
    "range": "A1:L12",
    "renderFormat": "png",
    "inspectKind": "workbook,sheet,table,formula,style,computedStyle,drawing,thread",
    "maxChars": 16000
  }
}
