{
  "name": "agent-readiness",
  "outputName": "agent-readiness.pptx",
  "slideSize": { "width": 1280, "height": 720 },
  "slides": [
    {
      "name": "Core workflow",
      "background": { "fill": "#F1F5F9", "mode": "solid" },
      "shapes": [
        {
          "name": "workflow-title",
          "geometry": "textbox",
          "position": { "left": 52, "top": 32, "width": 1176, "height": 72 },
          "fill": "transparent",
          "line": { "fill": "transparent", "width": 0 },
          "text": "OpenChestnut closes the presentation loop",
          "textStyle": { "fontFamily": "Arial", "fontSize": 38, "bold": true, "color": "#0F172A" }
        },
        {
          "name": "author-card",
          "geometry": "roundRect",
          "position": { "left": 72, "top": 154, "width": 300, "height": 130 },
          "fill": "#DBEAFE",
          "line": { "fill": "#2563EB", "width": 2 },
          "shadow": { "color": "#000000", "blurRadius": 10, "distance": 5, "direction": 45, "opacity": 0.2 },
          "text": "Create",
          "textStyle": { "fontFamily": "Arial", "fontSize": 28, "bold": true, "color": "#1E3A8A" }
        },
        {
          "name": "verify-card",
          "geometry": "roundRect",
          "position": { "left": 476, "top": 154, "width": 300, "height": 130 },
          "fill": "#DCFCE7",
          "line": { "fill": "#16A34A", "width": 2 },
          "shadow": { "color": "#000000", "blurRadius": 10, "distance": 5, "direction": 45, "opacity": 0.2 },
          "text": "Verify",
          "textStyle": { "fontFamily": "Arial", "fontSize": 28, "bold": true, "color": "#14532D" }
        },
        {
          "name": "deliver-card",
          "geometry": "roundRect",
          "position": { "left": 880, "top": 154, "width": 300, "height": 130 },
          "fill": "#F3E8FF",
          "line": { "fill": "#7C3AED", "width": 2 },
          "shadow": { "color": "#000000", "blurRadius": 10, "distance": 5, "direction": 45, "opacity": 0.2 },
          "text": "Deliver",
          "textStyle": { "fontFamily": "Arial", "fontSize": 28, "bold": true, "color": "#581C87" }
        },
        {
          "name": "workflow-evidence",
          "geometry": "textbox",
          "position": { "left": 72, "top": 350, "width": 720, "height": 220 },
          "fill": "transparent",
          "line": { "fill": "transparent", "width": 0 },
          "text": [
            {
              "runs": [
                { "text": "One canonical Office path", "style": { "fontSize": 25, "bold": true, "color": "#0F172A" } },
                { "text": " with an ", "style": { "fontSize": 22, "color": "#334155" } },
                { "text": "inspectable package", "style": { "fontSize": 22, "italic": true, "color": "#2563EB" }, "link": { "uri": "https://www.ecma-international.org/publications-and-standards/standards/ecma-376/" } }
              ]
            },
            {
              "bulletCharacter": "•",
              "marginLeft": 28,
              "indent": -14,
              "runs": [{ "text": "Semantic verification before visual review", "style": { "fontSize": 20, "color": "#334155" } }]
            },
            {
              "autoNumber": { "type": "arabicPeriod", "startAt": 1 },
              "marginLeft": 28,
              "indent": -14,
              "runs": [{ "text": "Render every slide at full size", "style": { "fontSize": 20, "color": "#334155" } }]
            }
          ]
        }
      ],
      "tables": [
        {
          "name": "workflow-matrix",
          "position": { "left": 840, "top": 350, "width": 340, "height": 220 },
          "values": [["Gate", "State"], ["Semantic", "Pass"], ["Visual", "Review"]],
          "styleOptions": { "headerRow": true, "bandedRows": true }
        }
      ],
      "connectors": [
        {
          "name": "create-to-verify",
          "connectorType": "straight",
          "fromName": "author-card",
          "toName": "verify-card",
          "start": { "x": 372, "y": 219 },
          "end": { "x": 476, "y": 219 },
          "line": { "fill": "#475569", "width": 2, "endArrow": "triangle" }
        },
        {
          "name": "verify-to-deliver",
          "connectorType": "elbow",
          "fromName": "verify-card",
          "toName": "deliver-card",
          "start": { "x": 776, "y": 219 },
          "end": { "x": 880, "y": 235 },
          "line": { "fill": "#475569", "width": 2, "startArrow": "triangle", "endArrow": "triangle" }
        }
      ]
    },
    {
      "name": "Literal charts",
      "background": { "fill": "#FFF7ED", "mode": "solid" },
      "shapes": [
        {
          "name": "charts-title",
          "geometry": "textbox",
          "position": { "left": 52, "top": 32, "width": 1176, "height": 64 },
          "fill": "transparent",
          "line": { "fill": "transparent", "width": 0 },
          "text": "Literal-data charts stay editable",
          "textStyle": { "fontFamily": "Arial", "fontSize": 36, "bold": true, "color": "#0F172A" }
        }
      ],
      "charts": [
        {
          "name": "readiness-bar",
          "chartType": "bar",
          "title": "Readiness",
          "position": { "left": 44, "top": 130, "width": 370, "height": 330 },
          "categories": ["Create", "Inspect", "Render"],
          "series": [{ "name": "Score", "values": [78, 92, 85], "color": "#2563EB" }],
          "legend": false,
          "dataLabels": { "showValue": true, "position": "outsideEnd" },
          "axes": { "category": { "title": "Gate" }, "value": { "title": "Score", "min": 0, "max": 100, "majorUnit": 20 } }
        },
        {
          "name": "trend-line",
          "chartType": "line",
          "title": "Weekly trend",
          "position": { "left": 454, "top": 130, "width": 370, "height": 330 },
          "categories": ["W1", "W2", "W3"],
          "series": [{ "name": "Passes", "values": [6, 9, 12], "color": "#16A34A", "line": { "fill": "#16A34A", "width": 2, "style": "dash" }, "marker": { "symbol": "circle", "size": 7, "fill": "#16A34A" } }],
          "legend": false
        },
        {
          "name": "coverage-pie",
          "chartType": "pie",
          "title": "Coverage mix",
          "position": { "left": 864, "top": 130, "width": 370, "height": 330 },
          "categories": ["Modeled", "Opaque"],
          "series": [{ "name": "Share", "values": [80, 20], "color": "#7C3AED" }],
          "legend": true,
          "dataLabels": { "showCategoryName": true, "showValue": true }
        }
      ]
    }
  ],
  "expectInspect": [
    { "kind": "shape", "pattern": "OpenChestnut closes the presentation loop" },
    { "kind": "table", "pattern": "workflow-matrix" },
    { "kind": "connector", "pattern": "verify-to-deliver" },
    { "kind": "chart", "pattern": "Coverage mix" }
  ],
  "qa": {
    "nativeRender": "auto",
    "inspectKind": "deck,slide,textbox,shape,table,chart,connector,textRange",
    "maxChars": 24000
  }
}
