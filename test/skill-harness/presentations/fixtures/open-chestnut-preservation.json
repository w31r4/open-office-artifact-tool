    { "kind": "table", "pattern": "roundtrip-table" },
    { "kind": "image", "pattern": "Roundtrip status before edit" },
    { "kind": "chart", "pattern": "Before roundtrip" },
    { "kind": "connector", "pattern": "editable-connector" }
