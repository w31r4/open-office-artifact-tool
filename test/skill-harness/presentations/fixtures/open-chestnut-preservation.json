      ],
      "charts": [
        {
          "name": "roundtrip-chart",
          "chartType": "bar",
          "title": "Before roundtrip",
          "position": { "left": 680, "top": 130, "width": 520, "height": 360 },
          "categories": ["Semantic", "Package", "Visual"],
          "series": [{ "name": "Checks", "values": [8, 12, 4], "color": "#2563EB" }],
          "legend": false,
          "dataLabels": { "showValue": true }
