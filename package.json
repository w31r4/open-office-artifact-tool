    "sharp": {
      "optional": true
    },
    "canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "pdfjs-dist": "^5.7.284",
    "playwright": "^1.61.1",
    "sharp": "^0.34.5"
  }
