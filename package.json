{
  "name": "open-office-artifact-tool",
  "version": "0.1.0",
  "description": "Clean-room Office/PDF artifact toolkit with agent-friendly inspect, resolve, help, render, and export APIs.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w31r4/open-office-artifact-tool.git"
  },
  "bugs": {
    "url": "https://github.com/w31r4/open-office-artifact-tool/issues"
  },
  "homepage": "https://github.com/w31r4/open-office-artifact-tool#readme",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./presentation-jsx": "./src/presentation-jsx/index.mjs",
    "./presentation-jsx/jsx-runtime": "./src/presentation-jsx/jsx-runtime.mjs",
    "./presentation-jsx/jsx-dev-runtime": "./src/presentation-jsx/jsx-dev-runtime.mjs",
    "./renderers/playwright": "./src/renderers/playwright.mjs",
    "./renderers/sharp": "./src/renderers/sharp.mjs",
    "./renderers/canvas": "./src/renderers/canvas.mjs",
    "./renderers/poppler": "./src/renderers/poppler.mjs",
    "./renderers/libreoffice": "./src/renderers/libreoffice.mjs",
    "./pdf/pdfjs": "./src/pdf/pdfjs.mjs",
    "./native/office-bridge": "./src/native/office-bridge.mjs",
    "./codecs/openxml-wasm": "./src/codecs/openxml-wasm.mjs",
    "./codecs/openxml-wasm/wire": "./src/generated/open_office/artifact/v1/office_artifact_pb.js"
  },
  "files": [
    "src/**",
    "docs/**",
    "scripts/**",
    "examples/**",
    "skills/**",
    "proto/**",
    "runtime/openxml-wasm/**",
    "native/OpenXmlWasm/*.sln",
    "native/OpenXmlWasm/README.md",
    "native/OpenXmlWasm/src/OpenOffice.OpenXmlCodec/*.cs",
    "native/OpenXmlWasm/src/OpenOffice.OpenXmlCodec/*.csproj",
    "native/OpenXmlWasm/src/OpenOffice.OpenXmlCodec/packages.lock.json",
    "native/OpenXmlWasm/src/OpenOffice.OpenXmlCodec/Properties/*.cs",
    "native/OpenXmlWasm/src/OpenOffice.OpenXmlWasm/*.cs",
    "native/OpenXmlWasm/src/OpenOffice.OpenXmlWasm/*.csproj",
    "native/OpenXmlWasm/src/OpenOffice.OpenXmlWasm/*.mjs",
    "native/OpenXmlWasm/src/OpenOffice.OpenXmlWasm/*.json",
    "native/OpenXmlWasm/tests/OpenOffice.OpenXmlCodec.Tests/*.cs",
    "native/OpenXmlWasm/tests/OpenOffice.OpenXmlCodec.Tests/*.csproj",
    "native/OpenXmlWasm/tests/OpenOffice.OpenXmlCodec.Tests/packages.lock.json",
    "native/OfficeBridge/*.sln",
    "native/OfficeBridge/src/*.cs",
    "native/OfficeBridge/src/*.csproj",
    "native/OfficeBridge/tests/*.cs",
    "native/OfficeBridge/tests/*.csproj",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "LICENSE"
  ],
  "scripts": {
    "proto:generate": "buf generate && node scripts/normalize-generated.mjs src/generated",
    "proto:check": "buf lint && npm run proto:generate && git diff --exit-code -- src/generated",
    "build:openxml-wasm": "node scripts/build-openxml-wasm.mjs",
    "verify:openxml-wasm-build": "node scripts/verify-openxml-wasm-build.mjs",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "release:check": "node scripts/release-check.mjs",
    "test": "node test/openxml-wasm.mjs && node test/spreadsheet.mjs && node test/spreadsheet-skill.mjs && node test/presentation.mjs && node test/presentation-jsx.mjs && node test/presentation-skill.mjs && node test/document.mjs && node test/document-skill.mjs && node test/ooxml-source-reference.mjs && node test/pdf.mjs && node test/pdf-skill.mjs && node test/verify.mjs && node test/render.mjs && node test/visual-baselines.mjs && node test/renderer-adapters.mjs && node test/playwright-renderer.mjs && node test/office-bridge.mjs && node test/examples.mjs && node test/release-check.mjs && node test/package-contents.mjs && node test/help.mjs",
    "test:openxml-wasm": "node test/openxml-wasm.mjs",
    "test:openxml-wasm-dotnet": "dotnet test native/OpenXmlWasm/OpenXmlWasm.sln --configuration Release",
    "test:spreadsheet": "node test/spreadsheet.mjs",
    "test:skill:spreadsheets": "node test/spreadsheet-skill.mjs",
    "test:presentation": "node test/presentation.mjs",
    "test:presentation-jsx": "node test/presentation-jsx.mjs",
    "test:skill:presentations": "node test/presentation-skill.mjs",
    "test:document": "node test/document.mjs",
    "test:skill:documents": "node test/document-skill.mjs",
    "test:pdf": "node test/pdf.mjs",
    "test:skill:pdf": "node test/pdf-skill.mjs",
    "test:verify": "node test/verify.mjs",
    "test:render": "node test/render.mjs",
    "test:visual-baselines": "node test/visual-baselines.mjs",
    "test:renderer-adapters": "node test/renderer-adapters.mjs",
    "test:playwright-renderer": "node test/playwright-renderer.mjs",
    "test:office-bridge": "node test/office-bridge.mjs",
    "test:office-bridge-dotnet": "dotnet test native/OfficeBridge",
    "test:examples": "node test/examples.mjs",
    "test:release-check": "node test/release-check.mjs",
    "test:package-contents": "node test/package-contents.mjs",
    "test:help": "node test/help.mjs",
    "test:pack": "node test/openxml-wasm-package.mjs && npm pack --dry-run"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1",
    "jszip": "^3.10.1"
  },
  "peerDependencies": {
    "canvas": ">=2.11.0",
    "pdfjs-dist": ">=4.0.0",
    "playwright": ">=1.40.0",
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "pdfjs-dist": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "sharp": {
      "optional": true
    },
    "canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.71.0",
    "@bufbuild/protoc-gen-es": "^2.12.1",
    "pdfjs-dist": "^5.7.284",
    "playwright": "^1.61.1",
    "sharp": "^0.34.5"
  }
}
