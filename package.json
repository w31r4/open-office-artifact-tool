{
  "name": "open-office-artifact-tool",
  "version": "0.2.0",
  "description": "Clean-room Office/PDF artifact toolkit with agent-friendly inspect, resolve, help, render, and export APIs.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w31r4/open-office-artifact-tool.git"
  },
  "bugs": {
    "url": "https://github.com/w31r4/open-office-artifact-tool/issues"
  },
  "homepage": "https://github.com/w31r4/open-office-artifact-tool#readme",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./presentation-jsx": "./src/presentation-jsx/index.mjs",
    "./presentation-jsx/jsx-runtime": "./src/presentation-jsx/jsx-runtime.mjs",
    "./presentation-jsx/jsx-dev-runtime": "./src/presentation-jsx/jsx-dev-runtime.mjs",
    "./renderers/playwright": "./src/renderers/playwright.mjs",
    "./renderers/sharp": "./src/renderers/sharp.mjs",
    "./renderers/canvas": "./src/renderers/canvas.mjs",
    "./renderers/poppler": "./src/renderers/poppler.mjs",
    "./renderers/libreoffice": "./src/renderers/libreoffice.mjs",
    "./pdf/pdfjs": "./src/pdf/pdfjs.mjs",
    "./pdf/mupdf": "./src/pdf/mupdf.mjs",
    "./native/office-bridge": "./src/native/office-bridge.mjs",
    "./codecs/open-chestnut": "./src/codecs/open-chestnut.mjs",
    "./codecs/open-chestnut/wire": "./src/generated/open_office/artifact/v1/office_artifact_pb.js"
  },
  "files": [
    "src/**",
    "docs/api.md",
    "docs/reference-skills.md",
    "docs/template-library-provenance.md",
    "examples/**",
    "skills/**",
    "proto/**",
    "runtime/open-chestnut/**",
    "native/OfficeBridge/*.sln",
    "native/OfficeBridge/src/*.cs",
    "native/OfficeBridge/src/*.csproj",
    "README.md",
    "README.en.md",
    "THIRD_PARTY_NOTICES.md",
    "LICENSE"
  ],
  "scripts": {
    "proto:generate": "buf generate && node scripts/normalize-generated.mjs src/generated",
    "proto:check": "buf lint && npm run proto:generate && git diff --exit-code -- src/generated",
    "build:open-chestnut": "node scripts/build-open-chestnut.mjs",
    "verify:open-chestnut-build": "node scripts/verify-open-chestnut-build.mjs",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "release:check": "node scripts/release-check.mjs",
    "test": "node test/open-chestnut.mjs && node test/font-metrics.mjs && node test/ooxml-source-reference.mjs && node test/spreadsheet.mjs && node test/spreadsheet-data-table.mjs && node test/spreadsheet-range-compat.mjs && node test/spreadsheet-sparkline.mjs && node test/spreadsheet-skill.mjs && node test/presentation.mjs && node test/presentation-jsx.mjs && node test/presentation-skill.mjs && node test/template-library.mjs && node test/default-template-library.mjs && node test/template-creator.mjs && node test/document.mjs && node test/document-skill.mjs && node test/pdf.mjs && node test/pdf-skill.mjs && node test/pdf-provider-skill.mjs && node test/reference-skills.mjs && node test/agent-evals.mjs && node test/verify.mjs && node test/render.mjs && node test/visual-baselines.mjs && node test/renderer-adapters.mjs && node test/playwright-renderer.mjs && node test/office-bridge.mjs && node test/examples.mjs && node test/release-check.mjs && node test/package-contents.mjs && node test/help.mjs",
    "eval:agents": "node scripts/run-agent-evals.mjs",
    "test:agent-evals": "node test/agent-evals.mjs",
    "test:open-chestnut": "node test/open-chestnut.mjs",
    "test:font-metrics": "node test/font-metrics.mjs",
    "test:open-chestnut-dotnet": "dotnet test native/OpenChestnut/OpenChestnut.sln --configuration Release",
    "test:spreadsheet": "node test/spreadsheet.mjs && node test/spreadsheet-range-compat.mjs && node test/spreadsheet-sparkline.mjs",
    "test:skill:spreadsheets": "node test/spreadsheet-skill.mjs",
    "test:presentation": "node test/presentation.mjs",
    "test:presentation-jsx": "node test/presentation-jsx.mjs",
    "test:skill:presentations": "node test/presentation-skill.mjs",
    "test:template-library": "node test/template-library.mjs",
    "test:default-template-library": "node test/default-template-library.mjs",
    "test:template-creator": "node test/template-creator.mjs",
    "test:document": "node test/document.mjs",
    "test:skill:documents": "node test/document-skill.mjs",
    "test:pdf": "node test/pdf.mjs",
    "test:skill:pdf": "node test/pdf-skill.mjs",
    "test:skill:pdf-providers": "node test/pdf-provider-skill.mjs",
    "test:skill:reference": "node test/reference-skills.mjs",
    "test:verify": "node test/verify.mjs",
    "test:render": "node test/render.mjs",
    "test:visual-baselines": "node test/visual-baselines.mjs",
    "test:renderer-adapters": "node test/renderer-adapters.mjs",
    "test:playwright-renderer": "node test/playwright-renderer.mjs",
    "test:office-bridge": "node test/office-bridge.mjs",
    "test:office-bridge-dotnet": "dotnet test native/OfficeBridge",
    "test:examples": "node test/examples.mjs",
    "test:release-check": "node test/release-check.mjs",
    "test:package-contents": "node test/package-contents.mjs",
    "test:help": "node test/help.mjs",
    "test:pack": "node test/open-chestnut-package.mjs && npm pack --dry-run"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1",
    "jszip": "^3.10.1",
    "mupdf": "1.28.0"
  },
  "peerDependencies": {
    "canvas": ">=2.11.0",
    "pdfjs-dist": ">=4.0.0",
    "playwright": ">=1.40.0",
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "pdfjs-dist": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "sharp": {
      "optional": true
    },
    "canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.71.0",
    "@bufbuild/protoc-gen-es": "^2.12.1",
    "pdfjs-dist": "^5.7.284",
    "playwright": "^1.61.1",
    "sharp": "^0.34.5"
  }
}
